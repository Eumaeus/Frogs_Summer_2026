#!ctsdata
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1.1.text#Εἴπω τι τῶν εἰωθότων ὦ δέσποτα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:2.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:2.1.text#ἐφ' οἷς ἀεὶ γελῶσιν οἱ θεώμενοι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:3.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:3.1.text#νὴ τὸν Δί' ὅ τι βούλει γε, πλὴν “πιέζομαι,” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:4.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:4.1.text#τοῦτο δὲ φύλαξαι· πάνυ γάρ ἐστ' ἤδη χολή.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:5.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:5.1.text#μηδ' ἕτερον ἀστεῖόν τι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:5.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:5.2.text#πλήν γ' “ὡς θλίβομαι.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:6.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:6.1.text#τί δαί; τὸ πάνυ γέλοιον εἴπω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:6.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:6.2.text#νὴ Δία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:7.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:7.1.text#θαρρῶν γε· μόνον ἐκεῖν' ὅπως μὴ 'ρεῖς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:7.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:7.2.text#τὸ τί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:8.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:8.1.text#μεταβαλλόμενος τἀνάφορον ὅτι “χεζητιᾷς.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:9.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:9.1.text#μηδ' ὅτι τοσοῦτον ἄχθος ἐπ' ἐμαυτῷ φέρων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:10.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:10.1.text#εἰ μὴ καθαιρήσει τις, ἀποπαρδήσομαι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:11.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:11.1.text#μὴ δῆθ', ἱκετεύω, πλήν γ' ὅταν μέλλω 'ξεμεῖν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:12.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:12.1.text#τί δῆτ' ἔδει με ταῦτα τὰ σκεύη φέρειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:13.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:13.1.text#εἴπερ ποιήσω μηδὲν ὧνπερ Φρύνιχος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:14.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:14.1.text#εἴωθε ποιεῖν καὶ Λύκις κἀμειψίας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:16.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:16.1.text#μή νυν ποιήσῃς· ὡς ἐγὼ θεώμενος,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:17.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:17.1.text#ὅταν τι τούτων τῶν σοφισμάτων ἴδω,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:18.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:18.1.text#πλεῖν ἢ 'νιαυτῷ πρεσβύτερος ἀπέρχομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:19.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:19.1.text#ὢ τρισκακοδαίμων ἄρ' ὁ τράχηλος οὑτοσί,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:20.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:20.1.text#ὅτι θλίβεται μέν, τὸ δὲ γέλοιον οὐκ ἐρεῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:21.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:21.1.text#εἶτ' οὐχ ὕβρις ταῦτ' ἐστὶ καὶ πολλὴ τρυφή,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:22.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:22.1.text#ὅτ' ἐγὼ μὲν ὢν Διόνυσος υἱὸς Σταμνίου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:23.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:23.1.text#αὐτὸς βαδίζω καὶ πονῶ, τοῦτον δ' ὀχῶ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:24.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:24.1.text#ἵνα μὴ ταλαιπωροῖτο μηδ' ἄχθος φέροι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:25.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:25.1.text#οὐ γὰρ φέρω 'γώ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:25.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:25.2.text#πῶς φέρεις γὰρ ὅς γ' ὀχεῖ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:26.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:26.1.text#φέρων γε ταυτί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:26.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:26.2.text#τίνα τρόπον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:26.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:26.3.text#βαρέως πάνυ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:27.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:27.1.text#οὔκουν τὸ βάρος τοῦθ' ὃ σὺ φέρεις ὄνος φέρει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:28.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:28.1.text#οὐ δῆθ' ὅ γ' ἔχω 'γὼ καὶ φέρω μὰ τὸν Δί' οὔ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:29.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:29.1.text#πῶς γὰρ φέρεις, ὅς γ' αὐτὸς ὑφ' ἑτέρου φέρει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:30.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:30.1.text#οὐκ οἶδ'· ὁ δ' ὦμος οὑτοσὶ πιέζεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:31.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:31.1.text#σὺ δ' οὖν ἐπειδὴ τὸν ὄνον οὐ φῄς σ' ὠφελεῖν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:32.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:32.1.text#ἐν τῷ μέρει σὺ τὸν ὄνον ἀράμενος φέρε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:33.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:33.1.text#οἴμοι κακοδαίμων· τί γὰρ ἐγὼ οὐκ ἐναυμάχουν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:34.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:34.1.text#ἦ τἄν σε κωκύειν ἂν ἐκέλευον μακρά.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:35.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:35.1.text#κατάβα πανοῦργε. καὶ γὰρ ἐγγὺς τῆς θύρας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:36.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:36.1.text#ἤδη βαδίζων εἰμὶ τῆσδ', οἷ πρῶτά με
urn:cts:greekLit:tlg0019.tlg009.fu.sp:37.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:37.1.text#ἔδει τραπέσθαι. παιδίον, παῖ, ἠμί, παῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:38.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:38.1.text#τίς τὴν θύραν ἐπάταξεν; ὡς κενταυρικῶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:39.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:39.1.text#ἐνήλαθ' ὅστις· εἰπέ μοι τουτὶ τί ἦν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.1.text#ὁ παῖς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.2.text#τί ἔστιν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.3.text#οὐκ ἐνεθυμήθης;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.4.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:40.4.text#τὸ τί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:41.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:41.1.text#ὡς σφόδρα μ' ἔδεισε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:41.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:41.2.text#νὴ Δία μὴ μαίνοιό γε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:42.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:42.1.text#οὔ τοι μὰ τὴν Δήμητρα δύναμαι μὴ γελᾶν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:43.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:43.1.text#καίτοι δάκνω γ' ἐμαυτόν· ἀλλ' ὅμως γελῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:44.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:44.1.text#ὦ δαιμόνιε πρόσελθε· δέομαι γάρ τί σου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:45.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:45.1.text#ἀλλ' οὐχ οἷός τ' εἴμ' ἀποσοβῆσαι τὸν γέλων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:46.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:46.1.text#ὁρῶν λεοντῆν ἐπὶ κροκωτῷ κειμένην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:47.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:47.1.text#τίς ὁ νοῦς; τί κόθορνος καὶ ῥόπαλον ξυνηλθέτην;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:48.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:48.1.text#ποῖ γῆς ἀπεδήμεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:48.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:48.2.text#ἐπεβάτευον Κλεισθένει-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:49.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:49.1.text#κἀναυμάχησας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:49.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:49.2.text#καὶ κατεδύσαμέν γε ναῦς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:50.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:50.1.text#τῶν πολεμίων ἢ δώδεκ' ἢ τρεῖς καὶ δέκα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:51.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:51.1.text#σφώ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:51.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:51.2.text#νὴ τὸν Ἀπόλλω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:51.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:51.3.text#κᾆτ' ἔγωγ' ἐξηγρόμην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:52.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:52.1.text#καὶ δῆτ' ἐπὶ τῆς νεὼς ἀναγιγνώσκοντί μοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:53.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:53.1.text#τὴν Ἀνδρομέδαν πρὸς ἐμαυτὸν ἐξαίφνης πόθος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:54.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:54.1.text#τὴν καρδίαν ἐπάταξε πῶς οἴει σφόδρα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:55.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:55.1.text#πόθος; πόσος τις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:55.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:55.2.text#μικρὸς ἡλίκος Μόλων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.1.text#γυναικός;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.2.text#οὐ δῆτ'.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.3.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.3.text#ἀλλὰ παιδός;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.4.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:56.4.text#οὐδαμῶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:57.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:57.1.text#ἀλλ' ἀνδρός;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:57.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:57.2.text#ἀπαπαί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:57.3.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:57.3.text#ξυνεγένου τῷ Κλεισθένει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:58.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:58.1.text#μὴ σκῶπτέ μ' ὦδέλφ'· οὐ γὰρ ἀλλ' ἔχω κακῶς·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:59.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:59.1.text#τοιοῦτος ἵμερός με διαλυμαίνεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:60.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:60.1.text#ποῖός τις ὦδελφίδιον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:60.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:60.2.text#οὐκ ἔχω φράσαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:61.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:61.1.text#ὅμως γε μέντοι σοι δι' αἰνιγμῶν ἐρῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:62.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:62.1.text#ἤδη ποτ' ἐπεθύμησας ἐξαίφνης ἔτνους;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:63.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:63.1.text#ἔτνους; βαβαιάξ, μυριάκις γ' ἐν τῷ βίῳ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:64.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:64.1.text#ἆρ' ἐκδιδάσκω τὸ σαφὲς ἢ 'τέρᾳ φράσω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:65.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:65.1.text#μὴ δῆτα περὶ ἔτνους γε· πάνυ γὰρ μανθάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:66.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:66.1.text#τοιουτοσὶ τοίνυν με δαρδάπτει πόθος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:67.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:67.1.text#Εὐριπίδου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:67.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:67.2.text#καὶ ταῦτα τοῦ τεθνηκότος;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:68.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:68.1.text#κοὐδείς γέ μ' ἂν πείσειεν ἀνθρώπων τὸ μὴ οὐκ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:69.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:69.1.text#ἐλθεῖν ἐπ' ἐκεῖνον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:69.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:69.2.text#πότερον εἰς Ἅιδου κάτω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:70.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:70.1.text#καὶ νὴ Δί' εἴ τί γ' ἔστιν ἔτι κατωτέρω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:71.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:71.1.text#τί βουλόμενος;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:71.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:71.2.text#δέομαι ποιητοῦ δεξιοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:72.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:72.1.text#οἱ μὲν γὰρ οὐκέτ' εἰσίν, οἱ δ' ὄντες κακοί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:73.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:73.1.text#τί δ'; οὐκ Ἰοφῶν ζῇ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:73.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:73.2.text#τοῦτο γάρ τοι καὶ μόνον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:74.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:74.1.text#ἔτ' ἐστὶ λοιπὸν ἀγαθόν, εἰ καὶ τοῦτ' ἄρα·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:75.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:75.1.text#οὐ γὰρ σάφ' οἶδ' οὐδ' αὐτὸ τοῦθ' ὅπως ἔχει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:76.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:76.1.text#εἶτ' οὐχὶ Σοφοκλέα πρότερον Εὐριπίδου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:77.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:77.1.text#μέλλεις ἀναγαγεῖν, εἴπερ ἐκεῖθεν δεῖ σ' ἄγειν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:78.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:78.1.text#οὐ πρίν γ' ἂν Ἰοφῶντ', ἀπολαβὼν αὐτὸν μόνον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:79.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:79.1.text#ἄνευ Σοφοκλέους ὅ τι ποιεῖ κωδωνίσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:80.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:80.1.text#κἄλλως ὁ μέν γ' Εὐριπίδης πανοῦργος ὢν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:81.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:81.1.text#κἂν ξυναποδρᾶναι δεῦρ' ἐπιχειρήσειέ μοι·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:82.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:82.1.text#ὁ δ' εὔκολος μὲν ἐνθάδ' εὔκολος δ' ἐκεῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:83.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:83.1.text#Ἀγάθων δὲ ποῦ 'στιν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:83.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:83.2.text#ἀπολιπών μ' ἀποίχεται,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:84.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:84.1.text#ἀγαθὸς ποιητὴς καὶ ποθεινὸς τοῖς φίλοις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:85.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:85.1.text#ποῖ γῆς ὁ τλήμων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:85.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:85.2.text#ἐς Μακάρων εὐωχίαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:86.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:86.1.text#ὁ δὲ Σενοκλέης;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:86.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:86.2.text#ἐξόλοιτο νὴ Δία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:87.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:87.1.text#Πυθάγγελος δέ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:87.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:87.2.text#περὶ ἐμοῦ δ' οὐδεὶς λόγος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:88.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:88.1.text#ἐπιτριβομένου τὸν ὦμον οὑτωσὶ σφόδρα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:89.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:89.1.text#οὔκουν ἕτερ' ἔστ' ἐνταῦθα μειρακύλλια
urn:cts:greekLit:tlg0019.tlg009.fu.sp:90.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:90.1.text#τραγῳδίας ποιοῦντα πλεῖν ἢ μύρια,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:91.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:91.1.text#Εὐριπίδου πλεῖν ἢ σταδίῳ λαλίστερα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:92.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:92.1.text#ἐπιφυλλίδες ταῦτ' ἐστὶ καὶ στωμύλματα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:93.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:93.1.text#χελιδόνων μουσεῖα, λωβηταὶ τέχνης,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:94.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:94.1.text#ἃ φροῦδα θᾶττον, ἢν μόνον χορὸν λάβῃ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:95.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:95.1.text#ἅπαξ προσουρήσαντα τῇ τραγῳδίᾳ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:96.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:96.1.text#γόνιμον δὲ ποιητὴν ἂν οὐχ εὕροις ἔτι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:97.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:97.1.text#ζητῶν ἄν, ὅστις ῥῆμα γενναῖον λάκοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:98.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:98.1.text#πῶς γόνιμον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:98.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:98.2.text#ὡδὶ γόνιμον, ὅστις φθέγξεται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:99.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:99.1.text#τοιουτονί τι παρακεκινδυνευμένον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:100.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:100.1.text#αἰθέρα Διὸς δωμάτιον, ἢ χρόνου πόδα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:101.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:101.1.text#ἢ φρένα μὲν οὐκ ἐθέλουσαν ὀμόσαι καθ' ἱερῶν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:102.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:102.1.text#γλῶτταν δ' ἐπιορκήσασαν ἰδίᾳ τῆς φρενός.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:103.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:103.1.text#σὲ δὲ ταῦτ' ἀρέσκει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:103.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:103.2.text#μἀλλὰ πλεῖν ἢ μαίνομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:104.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:104.1.text#ἦ μὴν κόβαλά γ' ἐστίν, ὡς καὶ σοὶ δοκεῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:105.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:105.1.text#μὴ τὸν ἐμὸν οἴκει νοῦν· ἔχεις γὰρ οἰκίαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:106.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:106.1.text#καὶ μὴν ἀτεχνῶς γε παμπόνηρα φαίνεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:107.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:107.1.text#δειπνεῖν με δίδασκε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:107.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:107.2.text#περὶ ἐμοῦ δ' οὐδεὶς λόγος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:108.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:108.1.text#ἀλλ' ὧνπερ ἕνεκα τήνδε τὴν σκευὴν ἔχων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:109.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:109.1.text#ἦλθον κατὰ σὴν μίμησιν, ἵνα μοι τοὺς ξένους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:110.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:110.1.text#τοὺς σοὺς φράσειας, εἰ δεοίμην, οἷσι σὺ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:111.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:111.1.text#ἐχρῶ τόθ', ἡνίκ' ἐπὶ τὸν Κέρβερον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:112.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:112.1.text#τούτους φράσον μοι, λιμένας ἀρτοπώλια
urn:cts:greekLit:tlg0019.tlg009.fu.sp:113.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:113.1.text#πορνεῖ' ἀναπαύλας ἐκτροπὰς κρήνας ὁδοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:114.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:114.1.text#πόλεις διαίτας πανδοκευτρίας, ὅπου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:115.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:115.1.text#κόρεις ὀλίγιστοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:115.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:115.2.text#περὶ ἐμοῦ δ' οὐδεὶς λόγος. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:116.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:116.1.text#ὦ σχέτλιε τολμήσεις γὰρ ἰέναι καὶ σύ γε;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:117.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:117.1.text#μηδὲν ἔτι πρὸς ταῦτ', ἀλλὰ φράζε τῶν ὁδῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:118.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:118.1.text#ὅπῃ τάχιστ' ἀφιξόμεθ' εἰς Ἅιδου κάτω·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:119.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:119.1.text#καὶ μήτε θερμὴν μήτ' ἄγαν ψυχρὰν φράσῃς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:120.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:120.1.text#φέρε δὴ τίν' αὐτῶν σοι φράσω πρώτην; τίνα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:121.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:121.1.text#μία μὲν γὰρ ἔστιν ἀπὸ κάλω καὶ θρανίου,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:122.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:122.1.text#κρεμάσαντι σαυτόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:122.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:122.2.text#παῦε, πνιγηρὰν λέγεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:123.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:123.1.text#ἀλλ' ἔστιν ἀτραπὸς ξύντομος τετριμμένη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:124.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:124.1.text#ἡ διὰ θυείας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:124.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:124.2.text#ἆρα κώνειον λέγεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:125.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:125.1.text#μάλιστά γε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:125.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:125.2.text#ψυχράν γε καὶ δυσχείμερον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:126.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:126.1.text#εὐθὺς γὰρ ἀποπήγνυσι τἀντικνήμια.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:127.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:127.1.text#βούλει κατάντη καὶ ταχεῖαν σοι φράσω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:128.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:128.1.text#νὴ τὸν Δί' ὡς ὄντος γε μὴ βαδιστικοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:129.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:129.1.text#καθέρπυσόν νυν ἐς Κεραμεικόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:129.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:129.2.text#κᾆτα τί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:130.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:130.1.text#ἀναβὰς ἐπὶ τὸν πύργον τὸν ὑψηλόν—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:130.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:130.2.text#τί δρῶ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:131.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:131.1.text#ἀφιεμένην τὴν λαμπάδ' ἐντεῦθεν θεῶ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:132.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:132.1.text#κἄπειτ' ἐπειδὰν φῶσιν οἱ θεώμενοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:133.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:133.1.text# “εἷναι,” τόθ' εἷναι καὶ σὺ σαυτόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:133.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:133.2.text#ποῖ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:133.3.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:133.3.text#κάτω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:134.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:134.1.text#ἀλλ' ἀπολέσαιμ' ἂν ἐγκεφάλου θρίω δύο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:135.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:135.1.text#οὐκ ἂν βαδίσαιμι τὴν ὁδὸν ταύτην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:135.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:135.2.text#τί δαί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:136.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:136.1.text#ἥνπερ σὺ τότε κατῆλθες.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:136.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:136.2.text#ἀλλ' ὁ πλοῦς πολύς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:137.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:137.1.text#εὐθὺς γὰρ ἐπὶ λίμνην μεγάλην ἥξεις πάνυ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:138.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:138.1.text#ἄβυσσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:138.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:138.2.text#εἶτα πῶς περαιωθήσομαι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:139.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:139.1.text#ἐν πλοιαρίῳ τυννουτῳί σ' ἀνὴρ γέρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:140.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:140.1.text#ναύτης διάξει δύ' ὀβολὼ μισθὸν λαβών.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:141.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:141.1.text#φεῦ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:141.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:141.2.text#ὡς μέγα δύνασθον πανταχοῦ τὼ δύ' ὀβολώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:142.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:142.1.text#πῶς ἠλθέτην κἀκεῖσε;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:142.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:142.2.text#Θησεὺς ἤγαγεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:143.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:143.1.text#μετὰ ταῦτ' ὄφεις καὶ θηρί' ὄψει μυρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:144.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:144.1.text#δεινότατα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:144.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:144.2.text#μή μ' ἔκπληττε μηδὲ δειμάτου·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:145.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:145.1.text#οὐ γάρ μ' ἀποτρέψεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:145.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:145.2.text#εἶτα βόρβορον πολὺν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:146.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:146.1.text#καὶ σκῶρ ἀείνων· ἐν δὲ τούτῳ κειμένους,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:147.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:147.1.text#εἴ που ξένον τις ἠδίκησε πώποτε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:148.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:148.1.text#ἢ παῖδα κινῶν τἀργύριον ὑφείλετο,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:149.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:149.1.text#ἢ μητέρ' ἠλόασεν, ἢ πατρὸς γνάθον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:150.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:150.1.text#ἐπάταξεν, ἢ 'πίορκον ὅρκον ὤμοσεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:151.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:151.1.text#ἢ Μορσίμου τις ῥῆσιν ἐξεγράψατο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:152.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:152.1.text#νὴ τοὺς θεοὺς ἐχρῆν γε πρὸς τούτοισι κεἰ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:153.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:153.1.text#τὴν πυρρίχην τις ἔμαθε τὴν Κινησίου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:154.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:154.1.text#ἐντεῦθεν αὐλῶν τίς σε περίεισιν πνοή,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:155.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:155.1.text#ὄψει τε φῶς κάλλιστον ὥσπερ ἐνθάδε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:156.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:156.1.text#καὶ μυρρινῶνας καὶ θιάσους εὐδαίμονας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:157.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:157.1.text#ἀνδρῶν γυναικῶν καὶ κρότον χειρῶν πολύν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:158.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:158.1.text#οὗτοι δὲ δὴ τίνες εἰσίν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:158.2.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:158.2.text#οἱ μεμυημένοι—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:159.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:159.1.text#νὴ τὸν Δί' ἐγὼ γοῦν ὄνος ἄγω μυστήρια.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:160.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:160.1.text#ἀτὰρ οὐ καθέξω ταῦτα τὸν πλείω χρόνον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:161.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:161.1.text#οἵ σοι φράσουσ' ἁπαξάπανθ' ὧν ἂν δέῃ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:162.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:162.1.text#οὗτοι γὰρ ἐγγύτατα παρ' αὐτὴν τὴν ὁδὸν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:163.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:163.1.text#ἐπὶ ταῖσι τοῦ Πλούτωνος οἰκοῦσιν θύραις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:164.1.speaker#Ἡρακλῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:164.1.text#καὶ χαῖρε πόλλ' ὦδελφέ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:164.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:164.2.text#νὴ Δία καὶ σύ γε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:165.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:165.1.text#ὑγίαινε. σὺ δὲ τὰ στρώματ' αὖθις λάμβανε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:166.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:166.1.text#πρὶν καὶ καταθέσθαι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:166.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:166.2.text#καὶ ταχέως μέντοι πάνυ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:167.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:167.1.text#μὴ δῆθ', ἱκετεύω σ', ἀλλὰ μίσθωσαί τινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:168.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:168.1.text#τῶν ἐκφερομένων, ὅστις ἐπὶ τοῦτ' ἔρχεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:169.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:169.1.text#ἐὰν δὲ μὴ εὕρω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:169.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:169.2.text#τότε μ' ἄγειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:169.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:169.3.text#καλῶς λέγεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:170.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:170.1.text#καὶ γάρ τιν' ἐκφέρουσι τουτονὶ νεκρόν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:171.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:171.1.text#οὗτος, σὲ λέγω μέντοι, σὲ τὸν τεθνηκότα·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:172.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:172.1.text#ἄνθρωπε βούλει σκευάρι' εἰς Ἅιδου φέρειν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:173.1.speaker#Νέκρος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:173.1.text#πόσ' ἄττα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:173.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:173.2.text#ταυτί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:173.3.speaker#Νέκρος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:173.3.text#δύο δραχμὰς μισθὸν τελεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:174.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:174.1.text#μὰ Δί' ἀλλ' ἔλαττον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:174.2.speaker#Νέκρος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:174.2.text#ὑπάγεθ' ὑμεῖς τῆς ὁδοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:175.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:175.1.text#ἀνάμεινον ὦ δαιμόνι', ἐὰν ξυμβῶ τί σοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:176.1.speaker#Νέκρος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:176.1.text#εἰ μὴ καταθήσεις δύο δραχμάς, μὴ διαλέγου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:177.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:177.1.text#λάβ' ἐννέ' ὀβολούς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:177.2.speaker#Νέκρος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:177.2.text#ἀναβιοίην νυν πάλιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:178.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:178.1.text#ὡς σεμνὸς ὁ κατάρατος· οὐκ οἰμώξεται;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:179.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:179.1.text#ἐγὼ βαδιοῦμαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:179.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:179.2.text#χρηστὸς εἶ καὶ γεννάδας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:180.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:180.1.text#χωρῶμεν ἐπὶ τὸ πλοῖον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:180.2.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:180.2.text#ὠὸπ παραβαλοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:181.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:181.1.text#τουτὶ τί ἔστι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:181.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:181.2.text#τοῦτο; λίμνη νὴ Δία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:182.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:182.1.text#αὕτη 'στὶν ἣν ἔφραζε, καὶ πλοῖόν γ' ὁρῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:183.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:183.1.text#νὴ τὸν Ποσειδῶ κἄστι γ' ὁ Χάρων οὑτοσί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:184.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:184.1.text#χαῖρ' ὦ Χάρων, χαῖρ' ὦ Χάρων, χαῖρ' ὦ Χάρων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:185.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:185.1.text#τίς εἰς ἀναπαύλας ἐκ κακῶν καὶ πραγμάτων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:186.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:186.1.text#τίς ἐς τὸ Λήθης πεδίον, ἢ 'ς Ὄνου πόκας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:187.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:187.1.text#ἢ 'ς Κερβερίους, ἢ 'ς κόρακας, ἢ 'πὶ Ταίναρον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:188.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:188.1.text#ἐγώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:188.2.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:188.2.text#ταχέως ἔμβαινε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:188.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:188.3.text#ποῖ σχήσειν δοκεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:189.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:189.1.text#ἐς κόρακας ὄντως;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:189.2.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:189.2.text#ναὶ μὰ Δία σοῦ γ' οὕνεκα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:190.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:190.1.text#ἔσβαινε δή.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:190.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:190.2.text#παῖ δεῦρο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:190.3.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:190.3.text#δοῦλον οὐκ ἄγω,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:191.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:191.1.text#εἰ μὴ νεναυμάχηκε τὴν περὶ τῶν κρεῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:192.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:192.1.text#μὰ τὸν Δί' οὐ γὰρ ἀλλ' ἔτυχον ὀφθαλμιῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:193.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:193.1.text#οὔκουν περιθρέξει δῆτα τὴν λίμνην κύκλῳ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:194.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:194.1.text#ποῦ δῆτ' ἀναμενῶ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:194.2.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:194.2.text#παρὰ τὸν Αὑαίνου λίθον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:195.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:195.1.text#ἐπὶ ταῖς ἀναπαύλαις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:195.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:195.2.text#μανθάνεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:195.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:195.3.text#πάνυ μανθάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:196.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:196.1.text#οἴμοι κακοδαίμων, τῷ ξυνέτυχον ἐξιών;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:197.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:197.1.text#κάθιζ' ἐπὶ κώπην. εἴ τις ἔτι πλεῖ, σπευδέτω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:198.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:198.1.text#οὗτος τί ποιεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:198.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:198.2.text#ὅ τι ποιῶ; τί δ' ἄλλο γ' ἢ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:199.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:199.1.text#ἵζω 'πὶ κώπην, οὗπερ ἐκέλευές με σύ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:200.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:200.1.text#οὔκουν καθεδεῖ δῆτ' ἐνθαδὶ γάστρων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:200.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:200.2.text#ἰδού.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:201.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:201.1.text#οὔκουν προβαλεῖ τὼ χεῖρε κἀκτενεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:201.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:201.2.text#ἰδού.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:202.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:202.1.text#οὐ μὴ φλυαρήσεις ἔχων ἀλλ' ἀντιβὰς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:203.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:203.1.text#ἐλᾷς προθύμως;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:203.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:203.2.text#κᾆτα πῶς δυνήσομαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:204.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:204.1.text#ἄπειρος ἀθαλάττωτος ἀσαλαμίνιος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:205.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:205.1.text#ὢν εἶτ' ἐλαύνειν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:205.2.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:205.2.text#ῥᾷστ'· ἀκούσει γὰρ μέλη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:206.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:206.1.text#κάλλιστ', ἐπειδὰν ἐμβάλῃς ἅπαξ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:206.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:206.2.text#τίνων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:207.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:207.1.text#βατράχων κύκνων θαυμαστά.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:207.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:207.2.text#κατακέλευε δή.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:208.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:208.1.text#ὦ ὀπὸπ ὦ ὀπόπ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:209.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:209.1.text#βρεκεκεκὲξ κοὰξ κοάξ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:210.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:210.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:211.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:211.1.text#λιμναῖα κρηνῶν τέκνα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:212.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:212.1.text#ξύναυλον ὕμνων βοὰν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:213.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:213.1.text#φθεγξώμεθ', εὔγηρυν ἐμὰν ἀοιδάν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:214.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:214.1.text#κοὰξ κοάξ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:215.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:215.1.text#ἣν ἀμφὶ Νυσήιον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:216.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:216.1.text#Διὸς Διόνυσον ἐν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:217.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:217.1.text#Λίμναισιν ἰαχήσαμεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:218.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:218.1.text#ἡνίχ' ὁ κραιπαλόκωμος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:219.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:219.1.text#τοῖς ἱεροῖσι Χύτροισι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:220.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:220.1.text#χωρεῖ κατ' ἐμὸν τέμενος λαῶν ὄχλος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:221.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:221.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:222.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:222.1.text#ἐγὼ δέ γ' ἀλγεῖν ἄρχομαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:223.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:223.1.text#τὸν ὄρρον ὦ κοὰξ κοάξ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:224.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:224.1.text#ὑμῖν δ' ἴσως οὐδὲν μέλει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:225.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:225.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:226.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:226.1.text#ἀλλ' ἐξόλοισθ' αὐτῷ “κοάξ”·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:227.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:227.1.text#οὐδὲν γάρ ἐστ' ἀλλ' ἢ “κοάξ”.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:228.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:228.1.text#εἰκότως γ' ὦ πολλὰ πράττων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:229.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:229.1.text#ἐμὲ γὰρ ἔστερξαν εὔλυροί τε Μοῦσαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:230.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:230.1.text#καὶ κεροβάτας Πὰν ὁ καλαμόφθογγα παίζων·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:231.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:231.1.text#προσεπιτέρπεται δ' ὁ φορμικτὰς Ἀπόλλων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:232.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:232.1.text#ἕνεκα δόνακος, ὃν ὑπολύριον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:233.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:233.1.text#ἔνυδρον ἐν λίμναις τρέφω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:235.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:235.1.text#βρεκεκεκὲξ κοάξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:236.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:236.1.text#ἐγὼ δὲ φλυκταίνας γ' ἔχω,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:237.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:237.1.text#χὠ πρωκτὸς ἰδίει πάλαι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:238.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:238.1.text#κᾆτ' αὐτίκ' ἐκκύψας ἐρεῖ—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:239.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:239.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:240.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:240.1.text#ἀλλ' ὦ φιλῳδὸν γένος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:241.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:241.1.text#παύσασθε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:241.2.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:241.2.text#μᾶλλον μὲν οὖν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:242.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:242.1.text#φθεγξόμεσθ', εἰ δή ποτ' εὐηλίοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:243.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:243.1.text#ἐν ἁμέραισιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:244.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:244.1.text#ἡλάμεσθα διὰ κυπείρου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:244b.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:244b.1.text#καὶ φλέω, χαίροντες ᾠδῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:245.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:245.1.text#πολυκολύμβοισι μέλεσιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:246.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:246.1.text#ἢ Διὸς φεύγοντες ὄμβρον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:247.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:247.1.text#ἔνυδρον ἐν βυθῷ χορείαν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:248.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:248.1.text#αἰόλαν ἐφθεγξάμεσθα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:249.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:249.1.text#πομφολυγοπαφλάσμασιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:251.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:251.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:252.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:252.1.text#τουτὶ παρ' ὑμῶν λαμβάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:253.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:253.1.text#δεινά τἄρα πεισόμεσθα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:254.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:254.1.text#δεινότερα δ' ἔγωγ', ἐλαύνων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:255.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:255.1.text#εἰ διαρραγήσομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:256.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:256.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:257.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:257.1.text#οἰμώζετ'· οὐ γάρ μοι μέλει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:258.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:258.1.text#ἀλλὰ μὴν κεκραξόμεσθά γ'
urn:cts:greekLit:tlg0019.tlg009.fu.sp:259.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:259.1.text#ὁπόσον ἡ φάρυξ ἂν ἡμῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:260.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:260.1.text#χανδάνῃ δι' ἡμέρας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:261.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:261.1.text#βρεκεκεκὲξ κοὰξ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:262.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:262.1.text#τούτῳ γὰρ οὐ νικήσετε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:263.1.speaker#Βάτραχοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:263.1.text#οὐδὲ μὴν ἡμᾶς σὺ πάντως.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:264.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:264.1.text#οὐδὲ μὴν ὑμεῖς γ' ἐμὲ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:264b.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:264b.1.text#οὐδέποτε· κεκράξομαι γὰρ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:265.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:265.1.text#κἂν δέῃ δι' ἡμέρας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:265b.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:265b.1.text#βρεκεκεκὲξ κοὰξ κοάξ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:266.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:266.1.text#ἕως ἂν ὑμῶν ἐπικρατήσω τῷ κοάξ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:267.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:267.1.text#βρεκεκεκὲξ κοὰξ κοάξ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:268.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:268.1.text#ἔμελλον ἄρα παύσειν ποθ' ὑμᾶς τοῦ κοάξ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:269.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:269.1.text#ὢ παῦε παῦε, παραβαλοῦ τὼ κωπίω,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:270.1.speaker#Χάρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:270.1.text#ἔκβαιν', ἀπόδος τὸν ναῦλον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:270.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:270.2.text#ἔχε δὴ τὠβολώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:271.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:271.1.text#ὁ Ξανθίας. ποῦ Ξανθίας; ἦ Ξανθία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:272.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:272.1.text#ἰαῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:272.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:272.2.text#βάδιζε δεῦρο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:272.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:272.3.text#χαῖρ' ὦ δέσποτα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:273.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:273.1.text#τί ἔστι τἀνταυθοῖ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:273.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:273.2.text#σκότος καὶ βόρβορος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:274.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:274.1.text#κατεῖδες οὖν που τοὺς πατραλοίας αὐτόθι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:275.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:275.1.text#καὶ τοὺς ἐπιόρκους, οὓς ἔλεγεν ἡμῖν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:275.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:275.2.text#σὺ δ' οὔ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:276.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:276.1.text#νὴ τὸν Ποσειδῶ 'γωγε, καὶ νυνί γ' ὁρῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:277.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:277.1.text#ἄγε δὴ τί δρῶμεν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:277.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:277.2.text#προϊέναι βέλτιστα νῷν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:278.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:278.1.text#ὡς οὗτος ὁ τόπος ἐστὶν οὗ τὰ θηρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:279.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:279.1.text#τὰ δείν' ἔφασκ' ἐκεῖνος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:279.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:279.2.text#ὡς οἰμώξεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:280.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:280.1.text#ἠλαζονεύεθ' ἵνα φοβηθείην ἐγώ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:281.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:281.1.text#εἰδώς με μάχιμον ὄντα φιλοτιμούμενος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:282.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:282.1.text#οὐδὲν γὰρ οὕτω γαῦρόν ἐσθ' ὡς Ἡρακλῆς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:283.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:283.1.text#ἐγὼ δέ γ' εὐξαίμην ἂν ἐντυχεῖν τινι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:284.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:284.1.text#λαβεῖν τ' ἀγώνισμ' ἄξιόν τι τῆς ὁδοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:285.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:285.1.text#νὴ τὸν Δία καὶ μὴν αἰσθάνομαι ψόφου τινός.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:286.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:286.1.text#ποῦ ποῦ 'στιν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:286.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:286.2.text#ἐξόπισθεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:286.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:286.3.text#ἐξόπισθ' ἴθι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:287.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:287.1.text#ἀλλ' ἐστὶν ἐν τῷ πρόσθε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:287.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:287.2.text#πρόσθε νυν ἴθι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:288.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:288.1.text#καὶ μὴν ὁρῶ νὴ τὸν Δία θηρίον μέγα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:289.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:289.1.text#ποῖόν τι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:289.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:289.2.text#δεινόν· παντοδαπὸν γοῦν γίγνεται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:290.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:290.1.text#τοτὲ μέν γε βοῦς, νυνὶ δ' ὀρεύς, τοτὲ δ' αὖ γυνὴ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:291.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:291.1.text#ὡραιοτάτη τις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:291.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:291.2.text#ποῦ 'στι; φέρ' ἐπ' αὐτὴν ἴω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:292.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:292.1.text#ἀλλ' οὐκέτ' αὖ γυνή 'στιν, ἀλλ' ἤδη κύων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:293.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:293.1.text#Ἔμπουσα τοίνυν ἐστί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:293.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:293.2.text#πυρὶ γοῦν λάμπεται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:294.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:294.1.text#ἅπαν τὸ πρόσωπον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:294.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:294.2.text#καὶ σκέλος χαλκοῦν ἔχει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:295.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:295.1.text#νὴ τὸν Ποσειδῶ, καὶ βολίτινον θάτερον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:296.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:296.1.text#σάφ' ἴσθι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:296.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:296.2.text#ποῖ δῆτ' ἂν τραποίμην;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:296.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:296.3.text#ποῖ δ' ἐγώ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:297.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:297.1.text#ἱερεῦ διαφύλαξόν μ', ἵν' ὦ σοι ξυμπότης.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:298.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:298.1.text#ἀπολούμεθ' ὦναξ Ἡράκλεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:298.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:298.2.text#οὐ μὴ καλεῖς μ'
urn:cts:greekLit:tlg0019.tlg009.fu.sp:299.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:299.1.text#ὦνθρωφ', ἱκετεύω, μηδὲ κατερεῖς τοὔνομα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:300.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:300.1.text#Διόνυσε τοίνυν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:300.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:300.2.text#τοῦτό γ' ἧττον θατέρου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:301.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:301.1.text#ἴθ' ᾗπερ ἔρχει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:301.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:301.2.text#δεῦρο δεῦρ' ὦ δέσποτα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:302.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:302.1.text#τί δ' ἔστι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:302.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:302.2.text#θάρρει· πάντ' ἀγαθὰ πεπράγαμεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:303.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:303.1.text#ἔξεστί θ' ὥσπερ Ἡγέλοχος ἡμῖν λέγειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:304.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:304.1.text# “ἐκ κυμάτων γὰρ αὖθις αὖ γαλῆν ὁρῶ.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:305.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:305.1.text#ἥμπουσα φρούδη.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:305.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:305.2.text#κατόμοσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:305.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:305.3.text#νὴ τὸν Δία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.1.text#καὖθις κατόμοσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.2.text#νὴ Δί'.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.3.text#ὄμοσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.4.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:306.4.text#νὴ Δία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:307.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:307.1.text#οἴμοι τάλας, ὡς ὠχρίασ' αὐτὴν ἰδών.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:308.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:308.1.text#ὁδὶ δὲ δείσας ὑπερεπυρρίασέ σου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:309.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:309.1.text#οἴμοι, πόθεν μοι τὰ κακὰ ταυτὶ προσέπεσεν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:310.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:310.1.text#τίν' αἰτιάσομαι θεῶν μ' ἀπολλύναι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:311.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:311.1.text#αἰθέρα Διὸς δωμάτιον ἢ χρόνου πόδα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.1.stage#αὐλεῖ τις ἔνδοθεν̓
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.1.text#οὗτος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.2.text#τί ἔστιν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.3.text#οὐ κατήκουσας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.4.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:312.4.text#τίνος;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:313.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:313.1.text#αὐλῶν πνοῆς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:313.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:313.2.text#ἔγωγε, καὶ δᾴδων γέ με
urn:cts:greekLit:tlg0019.tlg009.fu.sp:314.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:314.1.text#αὔρα τις εἰσέπνευσε μυστικωτάτη.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:315.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:315.1.text#ἀλλ' ἠρεμὶ πτήξαντες ἀκροασώμεθα. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:316.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:316.1.text#Ἴακχ' ὦ Ἴακχε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:317.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:317.1.text#Ἴακχ' ὦ Ἴακχε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:318.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:318.1.text#τοῦτ' ἔστ' ἐκεῖν' ὦ δέσποθ'· οἱ μεμυημένοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:319.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:319.1.text#ἐνταῦθά που παίζουσιν, οὓς ἔφραζε νῷν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:320.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:320.1.text#ᾄδουσι γοῦν τὸν Ἴακχον ὅνπερ Διαγόρας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:321.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:321.1.text#κἀμοὶ δοκοῦσιν. ἡσυχίαν τοίνυν ἄγειν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:322.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:322.1.text#βέλτιστόν ἐσθ', ἕως ἂν εἰδῶμεν σαφῶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:324.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:324.1.text#Ἴακχ' ὦ πολυτίμητ' ἐν ἕδραις ἐνθάδε ναίων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:325.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:325.1.text#Ἴακχ' ὦ Ἴακχε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:326.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:326.1.text#ἐλθὲ τόνδ' ἀνὰ λειμῶνα χορεύσων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:327.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:327.1.text#ὁσίους ἐς θιασώτας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:328.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:328.1.text#πολύκαρπον μὲν τινάσσων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:329.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:329.1.text#περὶ κρατὶ σῷ βρύοντα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:330.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:330.1.text#στέφανον μύρτων, θρασεῖ δ' ἐγκατακρούων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:331.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:331.1.text#ποδὶ τὰν ἀκόλαστον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:332.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:332.1.text#φιλοπαίγμονα τιμάν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:335.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:335.1.text#χαρίτων πλεῖστον ἔχουσαν μέρος, ἁγνάν, ἱερὰν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:336.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:336.1.text#ὁσίοις μύσταις χορείαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:337.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:337.1.text#ὦ πότνια πολυτίμητε Δήμητρος κόρη,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:338.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:338.1.text#ὡς ἡδύ μοι προσέπνευσε χοιρείων κρεῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:339.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:339.1.text#οὔκουν ἀτρέμ' ἕξεις, ἤν τι καὶ χορδῆς λάβῃς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:340.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:340.1.text#†ἔγειρε φλογέας λαμπάδας ἐν χερσὶ γὰρ ἥκει τινάσσων†,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:341.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:341.1.text#Ἴακχ' ὦ Ἴακχε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:342.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:342.1.text#νυκτέρου τελετῆς φωσφόρος ἀστήρ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:343.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:343.1.text#φλογὶ φέγγεται δὲ λειμών·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:345.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:345.1.text#γόνυ πάλλεται γερόντων·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:346.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:346.1.text#ἀποσείονται δὲ λύπας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:347.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:347.1.text#χρονίους τ' ἐτῶν παλαιῶν ἐνιαυτοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:350.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:350.1.text#ἱερᾶς ὑπὸ τιμᾶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:351.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:351.1.text#σὺ δὲ λαμπάδι † φλέγων†
urn:cts:greekLit:tlg0019.tlg009.fu.sp:352.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:352.1.text#προβάδην ἔξαγ' ἐπ' ἀνθηρὸν ἕλειον δάπεδον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:353.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:353.1.text#χοροποιὸν μάκαρ ἥβαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:354.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:354.1.text#εὐφημεῖν χρὴ κἀξίστασθαι τοῖς ἡμετέροισι χοροῖσιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:355.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:355.1.text#ὅστις ἄπειρος τοιῶνδε λόγων ἢ γνώμῃ μὴ καθαρεύει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:356.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:356.1.text#ἢ γενναίων ὄργια Μουσῶν μήτ' εἶδεν μήτ' ἐχόρευσεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:357.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:357.1.text#μηδὲ Κρατίνου τοῦ ταυροφάγου γλώττης Βακχεῖ' ἐτελέσθη,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:358.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:358.1.text#ἢ βωμολόχοις ἔπεσιν χαίρει μὴ ν' καιρῷ τοῦτο ποιοῦσιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:359.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:359.1.text#ἢ στάσιν ἐχθρὰν μὴ καταλύει μηδ' εὔκολός ἐστι πολίταις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:360.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:360.1.text#ἀλλ' ἀνεγείρει καὶ ῥιπίζει κερδῶν ἰδίων ἐπιθυμῶν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:361.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:361.1.text#ἢ τῆς πόλεως χειμαζομένης ἄρχων καταδωροδοκεῖται,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:362.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:362.1.text#ἢ προδίδωσιν φρούριον ἢ ναῦς, ἢ τἀπόρρητ' ἀποπέμπει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:363.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:363.1.text#ἐξ Αἰγίνης Θωρυκίων ὢν εἰκοστολόγος κακοδαίμων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:364.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:364.1.text#ἀσκώματα καὶ λίνα καὶ πίτταν διαπέμπων εἰς Ἐπίδαυρον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:365.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:365.1.text#ἢ χρήματα ταῖς τῶν ἀντιπάλων ναυσὶν παρέχειν τινὰ πείθει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:366.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:366.1.text#ἢ κατατιλᾷ τῶν Ἑκαταίων κυκλίοισι χοροῖσιν ὑπᾴδων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:367.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:367.1.text#ἢ τοὺς μισθοὺς τῶν ποιητῶν ῥήτωρ ὢν εἶτ' ἀποτρώγει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:368.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:368.1.text#κωμῳδηθεὶς ἐν ταῖς πατρίοις τελεταῖς ταῖς τοῦ Διονύσου·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:369.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:369.1.text#τούτοις αὐδῶ καὖθις ἀπαυδῶ καὖθις τὸ τρίτον μάλ' ἀπαυδῶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:370.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:370.1.text#ἐξίστασθαι μύσταισι χοροῖς· ὑμεῖς δ' ἀνεγείρετε μολπὴν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:371.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:371.1.text#καὶ παννυχίδας τὰς ἡμετέρας αἳ τῇδε πρέπουσιν ἑορτῇ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:372.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:372.1.text#χώρει νυν πᾶς ἀνδρείως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:373.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:373.1.text#ἐς τοὺς εὐανθεῖς κόλπους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:374.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:374.1.text#λειμώνων ἐγκρούων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:375.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:375.1.text#κἀπισκώπτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:376.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:376.1.text#καὶ παίζων καὶ χλευάζων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:377.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:377.1.text#ἠρίστηται δ' ἐξαρκούντως.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:378.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:378.1.text#ἀλλ' ἔμβα χὤπως ἀρεῖς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:379.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:379.1.text#τὴν Σώτειραν γενναίως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:380.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:380.1.text#τῇ φωνῇ μολπάζων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:381.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:381.1.text#ἣ τὴν χώραν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:382.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:382.1.text#σῴζειν φήσ' ἐς τὰς ὥρας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:383.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:383.1.text#κἂν Θωρυκίων μὴ βούληται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:384.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:384.1.text#ἄγε νυν ἑτέραν ὕμνων ἰδέαν τὴν καρποφόρον βασίλειαν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:385.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:385.1.text#Δήμητρα θεὰν ἐπικοσμοῦντες ζαθέαις μολπαῖς κελαδεῖτε. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:386.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:386.1.text#Δήμητερ ἁγνῶν ὀργίων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:387.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:387.1.text#ἄνασσα συμπαραστάτει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:388.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:388.1.text#καὶ σῷζε τὸν σαυτῆς χορόν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:389.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:389.1.text#καί μ' ἀσφαλῶς πανήμερον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:390.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:390.1.text#παῖσαί τε καὶ χορεῦσαι·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:391.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:391.1.text#καὶ πολλὰ μὲν γέλοιά μ' εἰ-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:392.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:392.1.text#πεῖν, πολλὰ δὲ σπουδαῖα, καὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:393.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:393.1.text#τῆς σῆς ἑορτῆς ἀξίως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:394.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:394.1.text#παίσαντα καὶ σκώψαντα νι-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:395.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:395.1.text#κήσαντα ταινιοῦσθαι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:396.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:396.1.text#ἄγ' εἶα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:397.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:397.1.text#νῦν καὶ τὸν ὡραῖον θεὸν παρακαλεῖτε δεῦρο
urn:cts:greekLit:tlg0019.tlg009.fu.sp:398.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:398.1.text#ᾠδαῖσι, τὸν ξυνέμπορον τῆσδε τῆς χορείας. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:399.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:399.1.text#Ἴακχε πολυτίμητε, μέλος ἑορτῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:400.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:400.1.text#ἥδιστον εὑρών, δεῦρο συνακολούθει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:401.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:401.1.text#πρὸς τὴν θεὸν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:402.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:402.1.text#καὶ δεῖξον ὡς ἄνευ πόνου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:403.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:403.1.text#πολλὴν ὁδὸν περαίνεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:404.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:404.1.text#Ἴακχε φιλοχορευτὰ συμπρόπεμπέ με. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:405.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:405.1.text#σὺ γὰρ κατεσχίσω μὲν ἐπὶ γέλωτι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:406.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:406.1.text#κἀπ' εὐτελείᾳ τόδε τὸ σανδαλίσκον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:407.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:407.1.text#καὶ τὸ ῥάκος,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:408.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:408.1.text#κἀξηῦρες ὥστ' ἀζημίους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:409.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:409.1.text#παίζειν τε καὶ χορεύειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:410.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:410.1.text#Ἴακχε φιλοχορευτὰ συμπρόπεμπέ με.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:411.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:411.1.text#καὶ γὰρ παραβλέψας τι μειρακίσκης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:412.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:412.1.text#νῦν δὴ κατεῖδον καὶ μάλ' εὐπροσώπου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:413.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:413.1.text#συμπαιστρίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:414.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:414.1.text#χιτωνίου παραρραγέν-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:415.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:415.1.text#τος τιτθίον προκύψαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:416.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:416.1.text#Ἴακχε φιλοχορευτὰ συμπρόπεμπέ με. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:417.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:417.1.text#ἐγὼ δ' ἀεί πως φιλακόλου-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:418.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:418.1.text#θός εἰμι καὶ μετ' αὐτῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:419.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:419.1.text#παίζων χορεύειν βούλομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:419.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:419.2.text#κἄγωγε πρός.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:420.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:420.1.text#βούλεσθε δῆτα κοινῇ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:421.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:421.1.text#σκώψωμεν Ἀρχέδημον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:422.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:422.1.text#ὃς ἑπτέτης ὢν οὐκ ἔφυσε φράτερας. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:423.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:423.1.text#νυνὶ δὲ δημαγωγεῖ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:424.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:424.1.text#ἐν τοῖς ἄνω νεκροῖσι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:425.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:425.1.text#κἀστὶν τὰ πρῶτα τῆς ἐκεῖ μοχθηρίας. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:426.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:426.1.text#τὸν Κλεισθένους δ' ἀκούω
urn:cts:greekLit:tlg0019.tlg009.fu.sp:427.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:427.1.text#ἐν ταῖς ταφαῖσι πρωκτὸν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:428.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:428.1.text#τίλλειν ἑαυτοῦ καὶ σπαράττειν τὰς γνάθους· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:429.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:429.1.text#κἀκόπτετ' ἐγκεκυφώς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:430.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:430.1.text#κἄκλαε κἀκεκράγει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:431.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:431.1.text#Σεβῖνον ὅστις ἐστὶν ἁναφλύστιος. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:432.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:432.1.text#καὶ Καλλίαν γέ φασι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:433.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:433.1.text#τοῦτον τὸν Ἱπποβίνου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:434.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:434.1.text#κύσθου λεοντῆν ναυμαχεῖν ἐνημμένον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:435.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:435.1.text#ἔχοιτ' ἂν οὖν φράσαι νῷν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:436.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:436.1.text#Πλούτων' ὅπου 'νθάδ' οἰκεῖ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:437.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:437.1.text#ξένω γάρ ἐσμεν ἀρτίως ἀφιγμένω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:438.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:438.1.text#μηδὲν μακρὰν ἀπέλθῃς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:439.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:439.1.text#μηδ' αὖθις ἐπανέρῃ με,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:440.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:440.1.text#ἀλλ' ἴσθ' ἐπ' αὐτὴν θύραν ἀφιγμένος. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:441.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:441.1.text#αἴροι' ἂν αὖθις ὦ παῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:442.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:442.1.text#τουτὶ τί ἦν τὸ πρᾶγμα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:443.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:443.1.text#ἀλλ' ἢ Διὸς Κόρινθος ἐν τοῖς στρώμασιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:444.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:444.1.text#χωρεῖτε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:445.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:445.1.text#νῦν ἱερὸν ἀνὰ κύκλον θεᾶς, ἀνθοφόρον ἀν' ἄλσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:446.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:446.1.text#παίζοντες οἷς μετουσία θεοφιλοῦς ἑορτῆς·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:447.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:447.1.text#ἐγὼ δὲ σὺν ταῖσιν κόραις εἶμι καὶ γυναιξίν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:448.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:448.1.text#οὗ παννυχίζουσιν θεᾷ, φέγγος ἱερὸν οἴσων. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:449.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:449.1.text#χωρῶμεν ἐς πολυρρόδους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:450.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:450.1.text#λειμῶνας ἀνθεμώδεις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:451.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:451.1.text#τὸν ἡμέτερον τρόπον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:452.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:452.1.text#τὸν καλλιχορώτατον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:453.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:453.1.text#παίζοντες, ὃν ὄλβιαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:454.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:454.1.text#Μοῖραι ξυνάγουσιν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:455.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:455.1.text#μόνοις γὰρ ἡμῖν ἥλιος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:456.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:456.1.text#καὶ φέγγος ἱλαρόν ἐστιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:457.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:457.1.text#ὅσοι μεμυήμεθ' εὐ-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:457b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:457b.1.text#σεβῆ τε διήγομεν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:458.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:458.1.text#τρόπον περὶ τοὺς ξένους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:459.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:459.1.text#καὶ τοὺς ἰδιώτας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:460.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:460.1.text#ἄγε δὴ τίνα τρόπον τὴν θύραν κόψω; τίνα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:461.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:461.1.text#πῶς ἐνθάδ' ἄρα κόπτουσιν οὑπιχώριοι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:462.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:462.1.text#οὐ μὴ διατρίψεις, ἀλλὰ γεύσει τῆς θύρας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:463.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:463.1.text#καθ' Ἡρακλέα τὸ σχῆμα καὶ τὸ λῆμ' ἔχων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:464.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:464.1.text#παῖ παῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:464.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:464.2.text#τίς οὗτος;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:464.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:464.3.text#Ἡρακλῆς ὁ καρτερός.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:465.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:465.1.text#ὦ βδελυρὲ κἀναίσχυντε καὶ τολμηρὲ σὺ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:466.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:466.1.text#καὶ μιαρὲ καὶ παμμίαρε καὶ μιαρώτατε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:467.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:467.1.text#ὃς τὸν κύν' ἡμῶν ἐξελάσας τὸν Κέρβερον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:468.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:468.1.text#ἀπῇξας ἄγχων κἀποδρὰς ᾤχου λαβών,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:469.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:469.1.text#ὃν ἐγὼ 'φύλαττον. ἀλλὰ νῦν ἔχει μέσος·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:470.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:470.1.text#τοία Στυγός σε μελανοκάρδιος πέτρα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:471.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:471.1.text#Ἀχερόντιός τε σκόπελος αἱματοσταγὴς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:472.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:472.1.text#φρουροῦσι, Κωκυτοῦ τε περίδρομοι κύνες,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:473.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:473.1.text#ἔχιδνά θ' ἑκατογκέφαλος, ἣ τὰ σπλάγχνα σου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:474.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:474.1.text#διασπαράξει, πλευμόνων τ' ἀνθάψεται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:475.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:475.1.text#Ταρτησία μύραινα· τὼ νεφρὼ δέ σου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:476.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:476.1.text#αὐτοῖσιν ἐντέροισιν ᾑματωμένω
urn:cts:greekLit:tlg0019.tlg009.fu.sp:477.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:477.1.text#διασπάσονται Γοργόνες Τειθράσιαι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:478.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:478.1.text#ἐφ' ἃς ἐγὼ δρομαῖον ὁρμήσω πόδα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:479.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:479.1.text#οὗτος τί δέδρακας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:479.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:479.2.text#ἐγκέχοδα· κάλει θεόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:480.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:480.1.text#ὦ καταγέλαστ' οὔκουν ἀναστήσει ταχὺ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:481.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:481.1.text#πρίν τινά σ' ἰδεῖν ἀλλότριον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:481.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:481.2.text#ἀλλ' ὡρακιῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:482.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:482.1.text#ἀλλ' οἶσε πρὸς τὴν καρδίαν μου σφογγιάν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:483.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:483.1.text#ἰδοὺ λαβέ, προσθοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:483.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:483.2.text#ποῦ 'στιν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:483.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:483.3.text#ὦ χρυσοῖ θεοὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:484.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:484.1.text#ἐνταῦθ' ἔχεις τὴν καρδίαν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:484.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:484.2.text#δείσασα γὰρ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:485.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:485.1.text#ἐς τὴν κάτω μου κοιλίαν καθείρπυσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:486.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:486.1.text#ὦ δειλότατε θεῶν σὺ κἀνθρώπων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:486.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:486.2.text#ἐγώ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:487.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:487.1.text#πῶς δειλὸς ὅστις σφογγιὰν ᾔτησά σε;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:488.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:488.1.text#οὐκ ἂν ἕτερός γ' αὔτ' ἠργάσατ' ἀνήρ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:488.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:488.2.text#ἀλλὰ τί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:489.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:489.1.text#κατέκειτ' ἂν ὀσφραινόμενος, εἴπερ δειλὸς ἦν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:490.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:490.1.text#ἐγὼ δ' ἀνέστην καὶ προσέτ' ἀπεψησάμην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:491.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:491.1.text#ἀνδρεῖά γ' ὦ Πόσειδον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:491.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:491.2.text#οἶμαι νὴ Δία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:492.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:492.1.text#σὺ δ' οὐκ ἔδεισας τὸν ψόφον τῶν ῥημάτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:493.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:493.1.text#καὶ τὰς ἀπειλάς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:493.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:493.2.text#οὐ μὰ Δί' οὐδ' ἐφρόντισα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:494.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:494.1.text#ἴθι νυν ἐπειδὴ ληματίας κἀνδρεῖος εἶ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:495.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:495.1.text#σὺ μὲν γενοῦ 'γὼ τὸ ῥόπαλον τουτὶ λαβὼν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:496.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:496.1.text#καὶ τὴν λεοντῆν, εἴπερ ἀφοβόσπλαγχνος εἶ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:497.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:497.1.text#ἐγὼ δ' ἔσομαί σοι σκευοφόρος ἐν τῷ μέρει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:498.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:498.1.text#φέρε δὴ ταχέως αὔτ'· οὐ γὰρ ἀλλὰ πειστέον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:499.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:499.1.text#καὶ βλέψον ἐς τὸν Ἡρακλειοξανθίαν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:500.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:500.1.text#εἰ δειλὸς ἔσομαι καὶ κατὰ σὲ τὸ λῆμ' ἔχων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:501.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:501.1.text#μὰ Δί' ἀλλ' ἀληθῶς οὑκ Μελίτης μαστιγίας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:502.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:502.1.text#φέρε νυν ἐγὼ τὰ στρώματ' αἴρωμαι ταδί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:503.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:503.1.text#ὦ φίλταθ' ἥκεις Ἡράκλεις; δεῦρ' εἴσιθι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:504.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:504.1.text#ἡ γὰρ θεός σ' ὡς ἐπύθεθ' ἥκοντ', εὐθέως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:505.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:505.1.text#ἔπεττεν ἄρτους, ἧψε κατερεικτῶν χύτρας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:506.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:506.1.text#ἔτνους δύ' ἢ τρεῖς, βοῦν ἀπηνθράκιζ' ὅλον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:507.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:507.1.text#πλακοῦντας ὤπτα κολλάβους. ἀλλ' εἴσιθι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:508.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:508.1.text#κάλλιστ', ἐπαινῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:508.2.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:508.2.text#μὰ τὸν Ἀπόλλω οὐ μή σ' ἐγὼ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:509.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:509.1.text#περιόψομἀπελθόντ', ἐπεί τοι καὶ κρέα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:510.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:510.1.text#ἀνέβραττεν ὀρνίθεια, καὶ τραγήματα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:511.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:511.1.text#ἔφρυγε, κᾦνον ἀνεκεράννυ γλυκύτατον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:512.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:512.1.text#ἀλλ' εἴσιθ' ἅμ' ἐμοί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:512.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:512.2.text#πάνυ καλῶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:512.3.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:512.3.text#ληρεῖς ἔχων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:513.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:513.1.text#οὐ γάρ σ' ἀφήσω. καὶ γὰρ αὐλητρίς γέ σοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:514.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:514.1.text#ἥδ' ἔνδον ἔσθ' ὡραιοτάτη κὠρχηστρίδες
urn:cts:greekLit:tlg0019.tlg009.fu.sp:515.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:515.1.text#ἕτεραι δύ' ἢ τρεῖς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:515.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:515.2.text#πῶς λέγεις; ὀρχηστρίδες;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:516.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:516.1.text#ἡβυλλιῶσαι κἄρτι παρατετιλμέναι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:517.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:517.1.text#ἀλλ' εἴσιθ', ὡς ὁ μάγειρος ἤδη τὰ τεμάχη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:518.1.speaker#Θεράπαινα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:518.1.text#ἔμελλ' ἀφαιρεῖν χἠ τράπεζ' εἰσῄρετο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:519.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:519.1.text#ἴθι νυν φράσον πρώτιστα ταῖς ὀρχηστρίσιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:520.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:520.1.text#ταῖς ἔνδον οὔσαις αὐτὸς ὅτι εἰσέρχομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:521.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:521.1.text#ὁ παῖς ἀκολούθει δεῦρο τὰ σκεύη φέρων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:522.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:522.1.text#ἐπίσχες οὗτος. οὔ τί που σπουδὴν ποιεῖ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:523.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:523.1.text#ὁτιή σε παίζων Ἡρακλέα 'νεσκεύασα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:524.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:524.1.text#οὐ μὴ φλυαρήσεις ἔχων ὦ Ξανθία,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:525.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:525.1.text#ἀλλ' ἀράμενος οἴσεις πάλιν τὰ στρώματα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:526.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:526.1.text#τί δ' ἔστιν; οὔ τι πού μ' ἀφελέσθαι διανοεῖ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:527.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:527.1.text#ἅδωκας αὐτός;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:527.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:527.2.text#οὐ τάχ', ἀλλ' ἤδη ποιῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:528.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:528.1.text#κατάθου τὸ δέρμα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:528.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:528.2.text#ταῦτ' ἐγὼ μαρτύρομαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:529.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:529.1.text#καὶ τοῖς θεοῖσιν ἐπιτρέπω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:529.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:529.2.text#ποίοις θεοῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:530.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:530.1.text#τὸ δὲ προσδοκῆσαί σ' οὐκ ἀνόητον καὶ κενὸν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:531.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:531.1.text#ὡς δοῦλος ὢν καὶ θνητὸς Ἀλκμήνης ἔσει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:532.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:532.1.text#ἀμέλει καλῶς· ἔχ' αὔτ'. ἴσως γάρ τοί ποτε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:533.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:533.1.text#ἐμοῦ δεηθείης ἄν, εἰ θεὸς θέλοι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:534.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:534.1.text#ταῦτα μὲν πρὸς ἀνδρός ἐστι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:534b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:534b.1.text#νοῦν ἔχοντος καὶ φρένας καὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:535.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:535.1.text#πολλὰ περιπεπλευκότος,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:536.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:536.1.text#μετακυλίνδειν αὑτὸν ἀεὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:537.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:537.1.text#πρὸς τὸν εὖ πράττοντα τοῖχον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:537b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:537b.1.text#μᾶλλον ἢ γεγραμμένην
urn:cts:greekLit:tlg0019.tlg009.fu.sp:538.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:538.1.text#εἰκόν' ἑστάναι, λαβόνθ' ἓν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:539.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:539.1.text#σχῆμα· τὸ δὲ μεταστρέφεσθαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:539b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:539b.1.text#πρὸς τὸ μαλθακώτερον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:540.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:540.1.text#δεξιοῦ πρὸς ἀνδρός ἐστι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:540b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:540b.1.text#καὶ φύσει Θηραμένους.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:541.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:541.1.text#οὐ γὰρ ἂν γέλοιον ἦν, εἰ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:542.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:542.1.text#Ξανθίας μὲν δοῦλος ὢν ἐν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:543.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:543.1.text#στρώμασιν Μιλησίοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:543b.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:543b.1.text#ἀνατετραμμένος κυνῶν ὀρ-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:544.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:544.1.text#χηστρίδ' εἶτ' ᾔτησεν ἀμίδ', ἐγὼ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:544b.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:544b.1.text#δὲ πρὸς τοῦτον βλέπων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:545.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:545.1.text#τοὐρεβίνθου 'δραττόμην, οὗ-
urn:cts:greekLit:tlg0019.tlg009.fu.sp:546.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:546.1.text#τος δ' ἅτ' ὢν αὐτὸς πανοῦργος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:547.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:547.1.text#εἶδε, κᾆτ' ἐκ τῆς γνάθου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:547b.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:547b.1.text#πὺξ πατάξας μοὐξέκοψε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:548.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:548.1.text#τοῦ χοροῦ τοὺς προσθίους; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:549.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:549.1.text#Πλαθάνη Πλαθάνη δεῦρ' ἔλθ', ὁ πανοῦργος οὑτοσί,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:550.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:550.1.text#ὃς ἐς τὸ πανδοκεῖον εἰσελθών ποτε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:551.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:551.1.text#ἑκκαίδεκ' ἄρτους κατέφαγ' ἡμῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:551.2.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:551.2.text#νὴ Δία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:552.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:552.1.text#ἐκεῖνος αὐτὸς δῆτα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:552.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:552.2.text#κακὸν ἥκει τινί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:553.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:553.1.text#καὶ κρέα γε πρὸς τούτοισιν ἀνάβραστ' εἴκοσιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:554.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:554.1.text#ἀν' ἡμιωβολιαῖα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:554.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:554.2.text#δώσει τις δίκην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:555.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:555.1.text#καὶ τὰ σκόροδα τὰ πολλά.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:555.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:555.2.text#ληρεῖς ὦ γύναι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:556.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:556.1.text#κοὐκ οἶσθ' ὅ τι λέγεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:556.2.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:556.2.text#οὐ μὲν οὖν με προσεδόκας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:557.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:557.1.text#ὁτιὴ κοθόρνους εἶχες, ἂν γνῶναί σ' ἔτι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:558.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:558.1.text#τί δαί; τὸ πολὺ τάριχος οὐκ εἴρηκά πω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:559.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:559.1.text#μὰ Δί' οὐδὲ τὸν τυρόν γε τὸν χλωρὸν τάλαν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:560.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:560.1.text#ὃν οὗτος αὐτοῖς τοῖς ταλάροις κατήσθιεν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:561.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:561.1.text#κἄπειτ' ἐπειδὴ τἀργύριον ἐπραττόμην,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:562.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:562.1.text#ἔβλεψεν ἔς με δριμὺ κἀμυκᾶτό γε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:563.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:563.1.text#τούτου πάνυ τοὔργον· οὗτος ὁ τρόπος πανταχοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:564.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:564.1.text#καὶ τὸ ξίφος γ' ἐσπᾶτο μαίνεσθαι δοκῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:565.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:565.1.text#νὴ Δία τάλαινα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:565.2.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:565.2.text#νὼ δὲ δεισάσα γέ που
urn:cts:greekLit:tlg0019.tlg009.fu.sp:566.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:566.1.text#ἐπὶ τὴν κατήλιφ' εὐθὺς ἀνεπηδήσαμεν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:567.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:567.1.text#ὁ δ' ᾤχετ' ἐξᾴξας γε τὰς ψιάθους λαβών.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:568.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:568.1.text#καὶ τοῦτο τούτου τοὔργον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:568.2.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:568.2.text#ἀλλ' ἐχρῆν τι δρᾶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:569.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:569.1.text#ἴθι δὴ κάλεσον τὸν προστάτην Κλέωνά μοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:570.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:570.1.text#σὺ δ' ἔμοιγ' ἐάνπερ ἐπιτύχῃς Ὑπέρβολον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:571.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:571.1.text#ἵν' αὐτὸν ἐπιτρίψωμεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:571.2.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:571.2.text#ὦ μιαρὰ φάρυξ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:572.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:572.1.text#ὡς ἡδέως ἄν σου λίθῳ τοὺς γομφίους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:573.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:573.1.text#κόπτοιμ' ἄν, οἷς μου κατέφαγες τὰ φορτία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:574.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:574.1.text#ἐγὼ δέ γ' ἐς τὸ βάραθρον ἐμβάλοιμί σε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:575.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:575.1.text#ἐγὼ δὲ τὸν λάρυγγ' ἂν ἐκτέμοιμί σου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:576.1.speaker#Πανδοκευτρία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:576.1.text#δρέπανον λαβοῦσ', ᾧ τὰς χόλικας κατέσπασας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:577.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:577.1.text#ἀλλ' εἶμ' ἐπὶ τὸν Κλέων', ὃς αὐτοῦ τήμερον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:578.1.speaker#Πλαθάνη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:578.1.text#ἐκπηνιεῖται ταῦτα προσκαλούμενος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:579.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:579.1.text#κάκιστ' ἀπολοίμην, Ξανθίαν εἰ μὴ φιλῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:580.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:580.1.text#οἶδ' οἶδα τὸν νοῦν· παῦε παῦε τοῦ λόγου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:581.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:581.1.text#οὐκ ἂν γενοίμην Ἡρακλῆς ἄν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:581.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:581.2.text#μηδαμῶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:582.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:582.1.text#ὦ Ξανθίδιον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:582.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:582.2.text#καὶ πῶς ἂν Ἀλκμήνης ἐγὼ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:583.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:583.1.text#υἱὸς γενοίμην δοῦλος ἅμα καὶ θνητὸς ὤν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:584.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:584.1.text#οἶδ' οἶδ' ὅτι θυμοῖ, καὶ δικαίως αὐτὸ δρᾷς·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:585.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:585.1.text#κἂν εἴ με τύπτοις, οὐκ ἂν ἀντείποιμί σοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:586.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:586.1.text#ἀλλ' ἤν σε τοῦ λοιποῦ ποτ' ἀφέλωμαι χρόνου,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:587.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:587.1.text#πρόρριζος αὐτός, ἡ γυνή, τὰ παιδία,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:588.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:588.1.text#κάκιστ' ἀπολοίμην, κἀρχέδημος ὁ γλάμων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:589.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:589.1.text#δέχομαι τὸν ὅρκον κἀπὶ τούτοις λαμβάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:590.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:590.1.text#νῦν σὸν ἔργον ἔστ', ἐπειδὴ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:590b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:590b.1.text#τὴν στολὴν εἴληφας ἥνπερ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:591.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:591.1.text#εἶχες ἐξ ἀρχῆς πάλιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:592.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:592.1.text#ἀνανεάζειν […]
urn:cts:greekLit:tlg0019.tlg009.fu.sp:593.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:593.1.text#καὶ βλέπειν αὖθις τὸ δεινόν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:593b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:593b.1.text#τοῦ θεοῦ μεμνημένον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:594.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:594.1.text#ᾧπερ εἰκάζεις σεαυτόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:594b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:594b.1.text#εἰ δὲ παραληρῶν ἁλώσει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:595.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:595.1.text#κἀκβαλεῖς τι μαλθακόν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:595b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:595b.1.text#αὖθις αἴρεσθαί σ' ἀνάγκη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:596.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:596.1.text#'σται πάλιν τὰ στρώματα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:597.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:597.1.text#οὐ κακῶς ὦνδρες παραινεῖτ',
urn:cts:greekLit:tlg0019.tlg009.fu.sp:598.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:598.1.text#ἀλλὰ καὐτὸς τυγχάνω ταῦτ'
urn:cts:greekLit:tlg0019.tlg009.fu.sp:598b.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:598b.1.text#ἄρτι συννοούμενος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:599.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:599.1.text#ὅτι μὲν οὖν, ἢν χρηστὸν ᾖ τι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:600.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:600.1.text#ταῦτ' ἀφαιρεῖσθαι πάλιν πειράσεταί
urn:cts:greekLit:tlg0019.tlg009.fu.sp:600b.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:600b.1.text#μ' εὖ οἶδ' ὅτι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:601.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:601.1.text#ἀλλ' ὅμως ἐγὼ παρέξω
urn:cts:greekLit:tlg0019.tlg009.fu.sp:601b.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:601b.1.text#'μ' αὐτὸν ἀνδρεῖον τὸ λῆμα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:602.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:602.1.text#καὶ βλέποντ' ὀρίγανον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:603.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:603.1.text#δεῖν δ' ἔοικεν, ὡς ἀκούω
urn:cts:greekLit:tlg0019.tlg009.fu.sp:604.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:604.1.text#τῆς θύρας καὶ δὴ ψόφον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:605.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:605.1.text#ξυνδεῖτε ταχέως τουτονὶ τὸν κυνοκλόπον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:606.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:606.1.text#ἵνα δῷ δίκην· ἀνύετον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:606.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:606.2.text#ἥκει τῳ κακόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:607.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:607.1.text#οὐκ ἐς κόρακας; μὴ πρόσιτον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:607.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:607.2.text#εἶεν, καὶ μάχει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:608.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:608.1.text#ὁ Διτύλας χὠ Σκεβλύας χὠ Παρδόκας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:609.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:609.1.text#χωρεῖτε δευρὶ καὶ μάχεσθε τουτῳί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:610.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:610.1.text#εἶτ' οὐχὶ δεινὰ ταῦτα, τύπτειν τουτονὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:611.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:611.1.text#κλέπτοντα πρὸς τἀλλότρια;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:611.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:611.2.text#μἀλλ' ὑπερφυᾶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:612.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:612.1.text#σχέτλια μὲν οὖν καὶ δεινά.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:612.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:612.2.text#καὶ μὴν νὴ Δία
urn:cts:greekLit:tlg0019.tlg009.fu.sp:613.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:613.1.text#εἰ πώποτ' ἦλθον δεῦρ', ἐθέλω τεθνηκέναι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:614.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:614.1.text#ἢ 'κλεψα τῶν σῶν ἄξιόν τι καὶ τριχός.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:615.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:615.1.text#καί σοι ποιήσω πρᾶγμα γενναῖον πάνυ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:616.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:616.1.text#βασάνιζε γὰρ τὸν παῖδα τουτονὶ λαβών,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:617.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:617.1.text#κἄν ποτέ μ' ἕλῃς ἀδικοῦντ', ἀπόκτεινόν μ' ἄγων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:618.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:618.1.text#καὶ πῶς βασανίσω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:618.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:618.2.text#πάντα τρόπον, ἐν κλίμακι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:619.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:619.1.text#δήσας κρεμάσας ὑστριχίδι μαστιγῶν, δέρων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:620.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:620.1.text#στρεβλῶν, ἔτι δ' ἐς τὰς ῥῖνας ὄξος ἐγχέων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:621.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:621.1.text#πλίνθους ἐπιτιθείς, πάντα τἄλλα, πλὴν πράσῳ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:622.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:622.1.text#μὴ τύπτε τοῦτον μηδὲ γητείῳ νέῳ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:623.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:623.1.text#δίκαιος ὁ λόγος· κἄν τι πηρώσω γέ σου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:624.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:624.1.text#τὸν παῖδα τύπτων, τἀργύριόν σοι κείσεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:625.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:625.1.text#μὴ δῆτ' ἔμοιγ'. οὕτω δὲ βασάνιζ' ἀπαγαγών.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:626.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:626.1.text#αὐτοῦ μὲν οὖν, ἵνα σοὶ κατ' ὀφθαλμοὺς λέγῃ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:627.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:627.1.text#κατάθου σὺ τὰ σκεύη ταχέως, χὤπως ἐρεῖς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:628.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:628.1.text#ἐνταῦθα μηδὲν ψεῦδος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:628.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:628.2.text#ἀγορεύω τινὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:629.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:629.1.text#ἐμὲ μὴ βασανίζειν ἀθάνατον ὄντ'· εἰ δὲ μή,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:630.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:630.1.text#αὐτὸς σεαυτὸν αἰτιῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:630.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:630.2.text#λέγεις δὲ τί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:631.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:631.1.text#ἀθάνατος εἶναί φημι Διόνυσος Διός,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:632.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:632.1.text#τοῦτον δὲ δοῦλον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:632.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:632.2.text#ταῦτ' ἀκούεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:632.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:632.3.text#φήμ' ἐγώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:633.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:633.1.text#καὶ πολύ γε μᾶλλόν ἐστι μαστιγωτέος·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:634.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:634.1.text#εἴπερ θεὸς γάρ ἐστιν, οὐκ αἰσθήσεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:635.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:635.1.text#τί δῆτ', ἐπειδὴ καὶ σὺ φῂς εἶναι θεός,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:636.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:636.1.text#οὐ καὶ σὺ τύπτει τὰς ἴσας πληγὰς ἐμοί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:637.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:637.1.text#δίκαιος ὁ λόγος· χὠπότερόν γ' ἂν νῷν ἴδῃς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:638.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:638.1.text#κλαύσαντα πρότερον ἢ προτιμήσαντά τι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:639.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:639.1.text#τυπτόμενον, εἶναι τοῦτον ἡγοῦ μὴ θεόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:640.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:640.1.text#οὐκ ἔσθ' ὅπως οὐκ εἶ σὺ γεννάδας ἀνήρ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:641.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:641.1.text#χωρεῖς γὰρ ἐς τὸ δίκαιον. ἀποδύεσθε δή.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:642.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:642.1.text#πῶς οὖν βασανιεῖς νὼ δικαίως;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:642.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:642.2.text#ῥᾳδίως·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:643.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:643.1.text#πληγὴν παρὰ πληγὴν ἑκάτερον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:643.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:643.2.text#καλῶς λέγεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:644.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:644.1.text#ἰδού.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:644.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:644.2.text#σκόπει νυν ἤν μ' ὑποκινήσαντ' ἴδῃς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:645.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:645.1.text#ἤδη 'πάταξά σ'.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:645.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:645.2.text#οὐ μὰ Δί'.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:645.3.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:645.3.text#οὐδ' ἐμοὶ δοκεῖς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:646.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:646.1.text#ἀλλ' εἶμ' ἐπὶ τονδὶ καὶ πατάξω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:646.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:646.2.text#πηνίκα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:647.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:647.1.text#καὶ δὴ 'πάταξα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:647.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:647.2.text#κᾆτα πῶς οὐκ ἔπταρον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:648.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:648.1.text#οὐκ οἶδα· τουδὶ δ' αὖθις ἀποπειράσομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:649.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:649.1.text#οὔκουν ἀνύσεις τι; ἀτταταῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:649.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:649.2.text#τί τἀτταταῖ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:650.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:650.1.text#μῶν ὠδυνήθης;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:650.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:650.2.text#οὐ μὰ Δί' ἀλλ' ἐφρόντισα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:651.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:651.1.text#ὁπόθ' Ἡράκλεια τἀν Διομείοις γίγνεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:652.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:652.1.text#ἅνθρωπος ἱερός. δεῦρο πάλιν βαδιστέον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:653.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:653.1.text#ἰοὺ ἰού.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:653.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:653.2.text#τί ἔστιν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:653.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:653.3.text#ἱππέας ὁρῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:654.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:654.1.text#τί δῆτα κλάεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:654.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:654.2.text#κρομμύων ὀσφραίνομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:655.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:655.1.text#ἐπεὶ προτιμᾷς γ' οὐδέν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:655.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:655.2.text#οὐδέν μοι μέλει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:656.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:656.1.text#βαδιστέον τἄρ' ἐστὶν ἐπὶ τονδὶ πάλιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:657.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:657.1.text#οἴμοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:657.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:657.2.text#τί ἔστι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:657.3.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:657.3.text#τὴν ἄκανθαν ἐξελε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:658.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:658.1.text#τί τὸ πρᾶγμα τουτί; δεῦρο πάλιν βαδιστέον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:659.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:659.1.text#Ἄπολλον—ὅς που Δῆλον ἢ Πυθῶν' ἔχεις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:660.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:660.1.text#ἤλγησεν· οὐκ ἤκουσας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:660.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:660.2.text#οὐκ ἔγωγ', ἐπεὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:661.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:661.1.text#ἴαμβον Ἱππώνακτος ἀνεμιμνῃσκόμην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:662.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:662.1.text#οὐδὲν ποιεῖς γάρ· ἀλλὰ τὰς λαγόνας σπόδει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:663.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:663.1.text#μὰ τὸν Δί' ἀλλ' ἤδη πάρεχε τὴν γαστέρα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:664.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:664.1.text#Πόσειδον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:664.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:664.2.text#ἤλγησέν τις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:665.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:665.1.text#ὃς Αἰγαίου πρῶνας ἢ γλαυκᾶς μέδεις ἁλὸς ἐν βένθεσιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:668.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:668.1.text#οὔ τοι μὰ τὴν Δήμητρα δύναμαί πω μαθεῖν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:669.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:669.1.text#ὁπότερος ὑμῶν ἐστι θεός. ἀλλ' εἴσιτον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:670.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:670.1.text#ὁ δεσπότης γὰρ αὐτὸς ὑμᾶς γνώσεται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:671.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:671.1.text#χἠ Φερρέφατθ', ἅτ' ὄντε κἀκείνω θεώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:672.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:672.1.text#ὀρθῶς λέγεις· ἐβουλόμην δ' ἂν τοῦτό σε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:673.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:673.1.text#πρότερον νοῆσαι, πρὶν ἐμὲ τὰς πληγὰς λαβεῖν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:675.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:675.1.text#Μοῦσα χορῶν ἱερῶν· ἐπίβηθι καὶ ἔλθ' ἐπὶ τέρψιν ἀοιδᾶς ἐμᾶς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:676.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:676.1.text#τὸν πολὺν ὀψομένη λαῶν· ὄχλον, οὗ σοφίαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:677.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:677.1.text#μυρίαι κάθηνται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:678.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:678.1.text#φιλοτιμότεραι Κλεοφῶντος, ἐφ' οὗ δὴ χείλεσιν ἀμφιλάλοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:680.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:680.1.text#δεινὸν ἐπιβρέμεται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:681.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:681.1.text#Θρῃκία χελιδὼν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:682.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:682.1.text#†ἐπὶ βάρβαρον ἑζομένη πέταλον· †
urn:cts:greekLit:tlg0019.tlg009.fu.sp:683.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:683.1.text#κελαδεῖ δ' ἐπίκλαυτον ἀηδόνιον νόμον, ὡς ἀπολεῖται,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:685.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:685.1.text#κἂν ἴσαι γένωνται. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:686.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:686.1.text#τὸν ἱερὸν χορὸν δίκαιόν ἐστι χρηστὰ τῇ πόλει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:687.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:687.1.text#ξυμπαραινεῖν καὶ διδάσκειν. πρῶτον οὖν ἡμῖν δοκεῖ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:688.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:688.1.text#ἐξισῶσαι τοὺς πολίτας κἀφελεῖν τὰ δείματα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:689.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:689.1.text#κεἴ τις ἥμαρτε σφαλείς τι Φρυνίχου παλαίσμασιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:690.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:690.1.text#ἐγγενέσθαι φημὶ χρῆναι τοῖς ὀλισθοῦσιν τότε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:691.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:691.1.text#αἰτίαν ἐκθεῖσι λῦσαι τὰς πρότερον ἁμαρτίας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:692.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:692.1.text#εἶτ' ἄτιμόν φημι χρῆναι μηδέν' εἶν' ἐν τῇ πόλει·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:693.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:693.1.text#καὶ γὰρ αἰσχρόν ἐστι τοὺς μὲν ναυμαχήσαντας μίαν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:694.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:694.1.text#καὶ Πλαταιᾶς εὐθὺς εἶναι κἀντὶ δούλων δεσπότας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:695.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:695.1.text#κοὐδὲ ταῦτ' ἔγωγ' ἔχοιμ' ἂν μὴ οὐ καλῶς φάσκειν ἔχειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:696.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:696.1.text#ἀλλ' ἐπαινῶ· μόνα γὰρ αὐτὰ νοῦν ἔχοντ' ἐδράσατε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:697.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:697.1.text#πρὸς δὲ τούτοις εἰκὸς ὑμᾶς, οἳ μεθ' ὑμῶν πολλὰ δὴ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:698.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:698.1.text#χοἰ πατέρες ἐναυμάχησαν καὶ προσήκουσιν γένει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:699.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:699.1.text#τὴν μίαν ταύτην παρεῖναι ξυμφορὰν αἰτουμένοις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:700.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:700.1.text#ἀλλὰ τῆς ὀργῆς ἀνέντες ὦ σοφώτατοι φύσει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:701.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:701.1.text#πάντας ἀνθρώπους ἑκόντες συγγενεῖς κτησώμεθα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:702.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:702.1.text#κἀπιτίμους καὶ πολίτας, ὅστις ἂν ξυνναυμαχῇ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:703.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:703.1.text#εἰ δὲ ταῦτ' ὀγκωσόμεσθα κἀποσεμνυνούμεθα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:704.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:704.1.text#τὴν πόλιν καὶ ταῦτ' ἔχοντες κυμάτων ἐν ἀγκάλαις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:705.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:705.1.text#ὑστέρῳ χρόνῳ ποτ' αὖθις εὖ φρονεῖν οὐ δόξομεν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:706.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:706.1.text#εἰ δ' ἐγὼ ὀρθὸς ἰδεῖν βίον ἀνέρος ἢ τρόπον ὅστις ἔτ'
urn:cts:greekLit:tlg0019.tlg009.fu.sp:707.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:707.1.text#οἰμώξεται,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:708.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:708.1.text#οὐ πολὺν οὐδ' ὁ πίθηκος οὗτος ὁ νῦν ἐνοχλῶν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:709.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:709.1.text#Κλειγένης ὁ μικρός,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:710.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:710.1.text#ὁ πονηρότατος βαλανεὺς ὁπόσοι κρατοῦσι κυκησιτέφρου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:711.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:711.1.text#ψευδολίτρου κονίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:712.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:712.1.text#καὶ Κιμωλίας γῆς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:713.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:713.1.text#χρόνον ἐνδιατρίψει· ἰδὼν δὲ τάδ' οὐκ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:715.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:715.1.text#εἰρηνικὸς ἔσθ', ἵνα μή ποτε κἀποδυθῇ μεθύων ἄνευ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:716.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:716.1.text#ξύλου βαδίζων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:718.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:718.1.text#πολλάκις γ' ἡμῖν ἔδοξεν ἡ πόλις πεπονθέναι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:719.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:719.1.text#ταὐτὸν ἔς τε τῶν πολιτῶν τοὺς καλούς τε κἀγαθοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:720.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:720.1.text#ἔς τε τἀρχαῖον νόμισμα καὶ τὸ καινὸν χρυσίον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:721.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:721.1.text#οὔτε γὰρ τούτοισιν οὖσιν οὐ κεκιβδηλευμένοις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:722.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:722.1.text#ἀλλὰ καλλίστοις ἁπάντων, ὡς δοκεῖ, νομισμάτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:723.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:723.1.text#καὶ μόνοις ὀρθῶς κοπεῖσι καὶ κεκωδωνισμένοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:724.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:724.1.text#ἔν τε τοῖς Ἕλλησι καὶ τοῖς βαρβάροισι πανταχοῦ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:725.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:725.1.text#χρώμεθ' οὐδέν, ἀλλὰ τούτοις τοῖς πονηροῖς χαλκίοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:726.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:726.1.text#χθές τε καὶ πρώην κοπεῖσι τῷ κακίστῳ κόμματι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:727.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:727.1.text#τῶν πολιτῶν θ' οὓς μὲν ἴσμεν εὐγενεῖς καὶ σώφρονας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:728.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:728.1.text#ἄνδρας ὄντας καὶ δικαίους καὶ καλούς τε κἀγαθοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:729.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:729.1.text#καὶ τραφέντας ἐν παλαίστραις καὶ χοροῖς καὶ μουσικῇ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:730.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:730.1.text#προυσελοῦμεν, τοῖς δὲ χαλκοῖς καὶ ξένοις καὶ πυρρίαις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:731.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:731.1.text#καὶ πονηροῖς κἀκ πονηρῶν εἰς ἅπαντα χρώμεθα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:732.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:732.1.text#ὑστάτοις ἀφιγμένοισιν, οἷσιν ἡ πόλις πρὸ τοῦ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:733.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:733.1.text#οὐδὲ φαρμακοῖσιν εἰκῇ ῥᾳδίως ἐχρήσατ' ἄν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:734.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:734.1.text#ἀλλὰ καὶ νῦν ὦνόητοι μεταβαλόντες τοὺς τρόπους
urn:cts:greekLit:tlg0019.tlg009.fu.sp:735.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:735.1.text#χρῆσθε τοῖς χρηστοῖσιν αὖθις· καὶ κατορθώσασι γὰρ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:736.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:736.1.text#εὔλογον, κἄν τι σφαλῆτ', ἐξ ἀξίου γοῦν τοῦ ξύλου,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:737.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:737.1.text#ἤν τι καὶ πάσχητε, πάσχειν τοῖς σοφοῖς δοκήσετε. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:738.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:738.1.text#νὴ τὸν Δία τὸν σωτῆρα γεννάδας ἀνὴρ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:739.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:739.1.text#ὁ δεσπότης σου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:739.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:739.2.text#πῶς γὰρ οὐχὶ γεννάδας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:740.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:740.1.text#ὅστις γε πίνειν οἶδε καὶ βινεῖν μόνον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:741.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:741.1.text#τὸ δὲ μὴ πατάξαι σ' ἐξελεγχθέντ' ἄντικρυς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:742.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:742.1.text#ὅτι δοῦλος ὢν ἔφασκες εἶναι δεσπότης.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:743.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:743.1.text#ᾤμωξε μέντἄν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:743.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:743.2.text#τοῦτο μέντοι δουλικὸν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:744.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:744.1.text#εὐθὺς πεποίηκας, ὅπερ ἐγὼ χαίρω ποιῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:745.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:745.1.text#χαίρεις, ἱκετεύω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:745.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:745.2.text#μἀλλ' ἐποπτεύειν δοκῶ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:746.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:746.1.text#ὅταν καταράσωμαι λάθρᾳ τῷ δεσπότῃ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:747.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:747.1.text#τί δὲ τονθορύζων, ἡνίκ' ἂν πληγὰς λαβὼν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:748.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:748.1.text#πολλὰς ἀπίῃς θύραζε;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:748.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:748.2.text#καὶ τοῦθ' ἥδομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:749.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:749.1.text#τί δὲ πολλὰ πράττων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:749.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:749.2.text#ὡς μὰ Δί' οὐδὲν οἶδ' ἐγώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:750.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:750.1.text#ὁμόγνιε Ζεῦ· καὶ παρακούων δεσποτῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:751.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:751.1.text#ἅττ' ἂν λαλῶσι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:751.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:751.2.text#μἀλλὰ πλεῖν ἢ μαίνομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:752.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:752.1.text#τί δὲ τοῖς θύραζε ταῦτα καταλαλῶν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:752.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:752.2.text#ἐγώ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:753.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:753.1.text#μὰ Δί' ἀλλ' ὅταν δρῶ τοῦτο, κἀκμιαίνομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:754.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:754.1.text#ὦ Φοῖβ' Ἄπολλον ἔμβαλέ μοι τὴν δεξιάν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:755.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:755.1.text#καὶ δὸς κύσαι καὐτὸς κύσον, καί μοι φράσον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:756.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:756.1.text#πρὸς Διός, ὃς ἡμῖν ἐστιν ὁμομαστιγίας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:757.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:757.1.text#τίς οὗτος οὕνδον ἐστὶ θόρυβος καὶ βοὴ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:758.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:758.1.text#χὠ λοιδορησμός;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:758.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:758.2.text#Αἰσχύλου κεὐριπίδου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:759.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:759.1.text#ἆ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:759.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:759.2.text#πρᾶγμα πρᾶγμα μέγα κεκίνηται μέγα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:760.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:760.1.text#ἐν τοῖς νεκροῖσι καὶ στάσις πολλὴ πάνυ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:761.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:761.1.text#ἐκ τοῦ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:761.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:761.2.text#νόμος τις ἐνθάδ' ἐστὶ κείμενος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:762.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:762.1.text#ἀπὸ τῶν τεχνῶν ὅσαι μεγάλαι καὶ δεξιαί,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:763.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:763.1.text#τὸν ἄριστον ὄντα τῶν ἑαυτοῦ συντέχνων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:764.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:764.1.text#σίτησιν αὐτὸν ἐν πρυτανείῳ λαμβάνειν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:765.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:765.1.text#θρόνον τε τοῦ Πλούτωνος ἑξῆς—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:765.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:765.2.text#μανθάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:766.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:766.1.text#ἕως ἀφίκοιτο τὴν τέχνην σοφώτερος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:767.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:767.1.text#ἕτερός τις αὐτοῦ· τότε δὲ παραχωρεῖν ἔδει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:768.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:768.1.text#τί δῆτα τουτὶ τεθορύβηκεν Αἰσχύλον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:769.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:769.1.text#ἐκεῖνος εἶχε τὸν τραγῳδικὸν θρόνον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:770.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:770.1.text#ὡς ὢν κράτιστος τὴν τέχνην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:770.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:770.2.text#νυνὶ δὲ τίς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:771.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:771.1.text#ὅτε δὴ κατῆλθ' Εὐριπίδης, ἐπεδείκνυτο
urn:cts:greekLit:tlg0019.tlg009.fu.sp:772.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:772.1.text#τοῖς λωποδύταις καὶ τοῖσι βαλλαντιοτόμοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:773.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:773.1.text#καὶ τοῖσι πατραλοίαισι καὶ τοιχωρύχοις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:774.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:774.1.text#ὅπερ ἔστ' ἐν Ἅιδου πλῆθος, οἱ δ' ἀκροώμενοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:775.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:775.1.text#τῶν ἀντιλογιῶν καὶ λυγισμῶν καὶ στροφῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:776.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:776.1.text#ὑπερεμάνησαν κἀνόμισαν σοφώτατον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:777.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:777.1.text#κἄπειτ' ἐπαρθεὶς ἀντελάβετο τοῦ θρόνου,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:778.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:778.1.text#ἵν' Αἰσχύλος καθῆστο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:778.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:778.2.text#κοὐκ ἐβάλλετο;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:779.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:779.1.text#μὰ Δί' ἀλλ' ὁ δῆμος ἀνεβόα κρίσιν ποιεῖν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:780.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:780.1.text#ὁπότερος εἴη τὴν τέχνην σοφώτερος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:781.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:781.1.text#ὁ τῶν πανούργων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:781.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:781.2.text#νὴ Δί' οὐράνιόν γ' ὅσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:782.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:782.1.text#μετ' Αἰσχύλου δ' οὐκ ἦσαν ἕτεροι σύμμαχοι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:783.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:783.1.text#ὀλίγον τὸ χρηστόν ἐστιν, ὥσπερ ἐνθάδε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:784.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:784.1.text#τί δῆθ' ὁ Πλούτων δρᾶν παρασκευάζεται;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:785.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:785.1.text#ἀγῶνα ποιεῖν αὐτίκα μάλα καὶ κρίσιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:786.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:786.1.text#κἄλεγχον αὐτῶν τῆς τέχνης.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:786.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:786.2.text#κἄπειτα πῶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:787.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:787.1.text#οὐ καὶ Σοφοκλέης ἀντελάβετο τοῦ θρόνου;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:788.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:788.1.text#μὰ Δί' οὐκ ἐκεῖνος, ἀλλ' ἔκυσε μὲν Αἰσχύλον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:789.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:789.1.text#ὅτε δὴ κατῆλθε, κἀνέβαλε τὴν δεξιάν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:790.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:790.1.text#κἀκεῖνος ὑπεχώρησεν αὐτῷ τοῦ θρόνου·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:791.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:791.1.text#νυνὶ δ' ἔμελλεν, ὡς ἔφη Κλειδημίδης,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:792.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:792.1.text#ἔφεδρος καθεδεῖσθαι· κἂν μὲν Αἰσχύλος κρατῇ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:793.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:793.1.text#ἕξειν κατὰ χώραν· εἰ δὲ μή, περὶ τῆς τέχνης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:794.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:794.1.text#διαγωνιεῖσθ' ἔφασκε πρός γ' Εὐριπίδην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:795.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:795.1.text#τὸ χρῆμ' ἄρ' ἔσται;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:795.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:795.2.text#νὴ Δί' ὀλίγον ὕστερον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:796.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:796.1.text#κἀνταῦθα δὴ τὰ δεινὰ κινηθήσεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:797.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:797.1.text#καὶ γὰρ ταλάντῳ μουσικὴ σταθμήσεται—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:798.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:798.1.text#τί δέ; μειαγωγήσουσι τὴν τραγῳδίαν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:799.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:799.1.text#καὶ κανόνας ἐξοίσουσι καὶ πήχεις ἐπῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:800.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:800.1.text#καὶ πλαίσια ξύμπτυκτα—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:800.2.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:800.2.text#πλινθεύσουσι γάρ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:801.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:801.1.text#καὶ διαμέτρους καὶ σφῆνας. ὁ γὰρ Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:802.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:802.1.text#κατ' ἔπος βασανιεῖν φησι τὰς τραγῳδίας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:803.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:803.1.text#ἦ που βαρέως οἶμαι τὸν Αἰσχύλον φέρειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:804.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:804.1.text#ἔβλεψε γοῦν ταυρηδὸν ἐγκύψας κάτω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:805.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:805.1.text#κρινεῖ δὲ δὴ τίς ταῦτα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:805.2.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:805.2.text#τοῦτ' ἦν δύσκολον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:806.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:806.1.text#σοφῶν γὰρ ἀνδρῶν ἀπορίαν ηὑρισκέτην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:807.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:807.1.text#οὔτε γὰρ Ἀθηναίοισι συνέβαιν' Αἰσχύλος—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:808.1.speaker#Ξανθίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:808.1.text#πολλοὺς ἴσως ἐνόμιζε τοὺς τοιχωρύχους.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:809.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:809.1.text#λῆρόν τε τἄλλ' ἡγεῖτο τοῦ γνῶναι πέρι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:810.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:810.1.text#φύσεις ποιητῶν· εἶτα τῷ σῷ δεσπότῃ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:811.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:811.1.text#ἐπέτρεψαν, ὁτιὴ τῆς τέχνης ἔμπειρος ἦν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:812.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:812.1.text#ἀλλ' εἰσίωμεν· ὡς ὅταν γ' οἱ δεσπόται
urn:cts:greekLit:tlg0019.tlg009.fu.sp:813.1.speaker#Ἄιακος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:813.1.text#ἐσπουδάκωσι, κλαύμαθ' ἡμῖν γίγνεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:814.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:814.1.text#ἦ που δεινὸν ἐριβρεμέτας χόλον ἔνδοθεν ἕξει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:815.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:815.1.text#ἡνίκ' ἂν ὀξύλαλον παρίδῃ θήγοντος ὀδόντα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:816.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:816.1.text#ἀντιτέχνου· τότε δὴ μανίας ὑπὸ δεινῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:817.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:817.1.text#ὄμματα στροβήσεται.  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:818.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:818.1.text#ἔσται δ' ἱππολόφων τε λόγων κορυθαίολα νείκη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:819.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:819.1.text#σχινδαλάμων τε παραξόνια σμιλεύματά τ' ἔργων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:820.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:820.1.text#φωτὸς ἀμυνομένου φρενοτέκτονος ἀνδρὸς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:821.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:821.1.text#ῥήμαθ' ἱπποβάμονα. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:822.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:822.1.text#φρίξας δ' αὐτοκόμου λοφιᾶς λασιαύχενα χαίταν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:823.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:823.1.text#δεινὸν ἐπισκύνιον ξυνάγων βρυχώμενος ἥσει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:824.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:824.1.text#ῥήματα γομφοπαγῆ πινακηδὸν ἀποσπῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:825.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:825.1.text#γηγενεῖ φυσήματι· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:826.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:826.1.text#ἔνθεν δὴ στοματουργὸς ἐπῶν βασανίστρια λίσφη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:827.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:827.1.text#γλῶσσ' ἀνελισσομένη φθονεροὺς κινοῦσα χαλινοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:828.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:828.1.text#ῥήματα δαιομένη καταλεπτολογήσει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:829.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:829.1.text#πλευμόνων πολὺν πόνον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:830.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:830.1.text#οὐκ ἂν μεθείμην τοῦ θρόνου, μὴ νουθέτει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:831.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:831.1.text#κρείττων γὰρ εἶναί φημι τούτου τὴν τέχνην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:832.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:832.1.text#Αἰσχύλε τί σιγᾷς; αἰσθάνει γὰρ τοῦ λόγου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:833.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:833.1.text#ἀποσεμνυνεῖται πρῶτον, ἅπερ ἑκάστοτε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:834.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:834.1.text#ἐν ταῖς τραγῳδίαισιν ἐτερατεύετο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:835.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:835.1.text#ὦ δαιμόνι' ἀνδρῶν μὴ μεγάλα λίαν λέγε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:836.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:836.1.text#ἐγᾦδα τοῦτον καὶ διέσκεμμαι πάλαι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:837.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:837.1.text#ἄνθρωπον ἀγριοποιὸν αὐθαδόστομον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:838.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:838.1.text#ἔχοντ' ἀχάλινον ἀκρατὲς ἀπύλωτον στόμα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:839.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:839.1.text#ἀπεριλάλητον κομποφακελορρήμονα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:840.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:840.1.text#ἄληθες ὦ παῖ τῆς ἀρουραίας θεοῦ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:841.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:841.1.text#σὺ δή με ταῦτ' ὦ στωμυλιοσυλλεκτάδη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:842.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:842.1.text#καὶ πτωχοποιὲ καὶ ῥακιοσυρραπτάδη;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:843.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:843.1.text#ἀλλ' οὔ τι χαίρων αὔτ' ἐρεῖς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:843.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:843.2.text#παῦ' Αἰσχύλε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:844.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:844.1.text#καὶ μὴ πρὸς ὀργὴν σπλάγχνα θερμήνῃς κότῳ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:845.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:845.1.text#οὐ δῆτα πρίν γ' ἂν τοῦτον ἀποφήνω σαφῶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:846.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:846.1.text#τὸν χωλοποιὸν οἷος ὢν θρασύνεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:847.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:847.1.text#ἄρν' ἄρνα μέλανα παῖδες ἐξενέγκατε·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:848.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:848.1.text#τυφὼς γὰρ ἐκβαίνειν παρασκευάζεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:849.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:849.1.text#ὦ Κρητικὰς μὲν συλλέγων μονῳδίας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:850.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:850.1.text#γάμους δ' ἀνοσίους ἐσφέρων ἐς τὴν τέχνην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:851.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:851.1.text#ἐπίσχες οὗτος ὦ πολυτίμητ' Αἰσχύλε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:852.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:852.1.text#ἀπὸ τῶν χαλαζῶν δ' ὦ πόνηρ' Εὐριπίδη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:853.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:853.1.text#ἄναγε σεαυτὸν ἐκποδών, εἰ σωφρονεῖς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:854.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:854.1.text#ἵνα μὴ κεφαλαίῳ τὸν κρόταφόν σου ῥήματι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:855.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:855.1.text#θενὼν ὑπ' ὀργῆς ἐκχέῃ τὸν Τήλεφον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:856.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:856.1.text#σὺ δὲ μὴ πρὸς ὀργὴν Αἰσχύλ' ἀλλὰ πρᾳόνως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:857.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:857.1.text#ἔλεγχ' ἐλέγχου· λοιδορεῖσθαι δ' οὐ πρέπει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:858.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:858.1.text#ἄνδρας ποιητὰς ὥσπερ ἀρτοπώλιδας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:859.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:859.1.text#σὺ δ' εὐθὺς ὥσπερ πρῖνος ἐμπρησθεὶς βοᾷς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:860.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:860.1.text#ἕτοιμός εἰμ' ἔγωγε, κοὐκ ἀναδύομαι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:861.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:861.1.text#δάκνειν δάκνεσθαι πρότερος, εἰ τούτῳ δοκεῖ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:862.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:862.1.text#τἄπη, τὰ μέλη, τὰ νεῦρα τῆς τραγῳδίας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:863.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:863.1.text#καὶ νὴ Δία τὸν Πηλέα γε καὶ τὸν Αἴολον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:864.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:864.1.text#καὶ τὸν Μελέαγρον κἄτι μάλα τὸν Τήλεφον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:865.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:865.1.text#τί δαὶ σὺ βουλεύει ποιεῖν; λέγ' Αἰσχύλε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:866.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:866.1.text#ἐβουλόμην μὲν οὐκ ἐρίζειν ἐνθάδε·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:867.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:867.1.text#οὐκ ἐξ ἴσου γάρ ἐστιν ἁγὼν νῷν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:867.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:867.2.text#τί δαί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:868.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:868.1.text#ὅτι ἡ ποίησις οὐχὶ συντέθνηκέ μοι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:869.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:869.1.text#τούτῳ δὲ συντέθνηκεν, ὥσθ' ἕξει λέγειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:870.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:870.1.text#ὅμως δ' ἐπειδή σοι δοκεῖ, δρᾶν ταῦτα χρή.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:871.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:871.1.text#ἴθι νυν λιβανωτὸν δεῦρό τις καὶ πῦρ δότω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:872.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:872.1.text#ὅπως ἂν εὔξωμαι πρὸ τῶν σοφισμάτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:873.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:873.1.text#ἀγῶνα κρῖναι τόνδε μουσικώτατα·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:874.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:874.1.text#ὑμεῖς δὲ ταῖς Μούσαις τι μέλος ὑπᾴσατε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:875.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:875.1.text#ὦ Διὸς ἐννέα παρθένοι ἁγναὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:876.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:876.1.text#Μοῦσαι, λεπτολόγους ξυνετὰς φρένας αἳ καθορᾶτε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:877.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:877.1.text#ἀνδρῶν γνωμοτύπων, ὅταν εἰς ἔριν ὀξυμερίμνοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:878.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:878.1.text#ἔλθωσι στρεβλοῖσι παλαίσμασιν ἀντιλογοῦντες,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:879.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:879.1.text#ἔλθετ' ἐποψόμεναι δύναμιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:880.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:880.1.text#δεινοτάτοιν στομάτοιν πορίσασθαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:881.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:881.1.text#ῥήματα καὶ παραπρίσματ' ἐπῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:882.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:882.1.text#νῦν γὰρ ἀγὼν σοφίας ὁ μέγας χωρεῖ πρὸς ἔργον ἤδη.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:885.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:885.1.text#εὔχεσθε δὴ καὶ σφώ τι πρὶν τἄπη λέγειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:886.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:886.1.text#Δήμητερ ἡ θρέψασα τὴν ἐμὴν φρένα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:887.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:887.1.text#εἶναί με τῶν σῶν ἄξιον μυστηρίων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:888.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:888.1.text#ἐπίθες λαβὼν δὴ καὶ σὺ λιβανωτόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:888.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:888.2.text#καλῶς·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:889.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:889.1.text#ἕτεροι γάρ εἰσιν οἷσιν εὔχομαι θεοῖς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:890.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:890.1.text#ἴδιοί τινές σοι, κόμμα καινόν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:890.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:890.2.text#καὶ μάλα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:891.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:891.1.text#ἴθι δὴ προσεύχου τοῖσιν ἰδιώταις θεοῖς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:892.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:892.1.text#αἰθὴρ ἐμὸν βόσκημα καὶ γλώσσης στρόφιγξ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:893.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:893.1.text#καὶ ξύνεσι καὶ μυκτῆρες ὀσφραντήριοι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:894.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:894.1.text#ὀρθῶς μ' ἐλέγχειν ὧν ἂν ἅπτωμαι λόγων. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:895.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:895.1.text#καὶ μὴν ἡμεῖς ἐπιθυμοῦμεν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:896.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:896.1.text#παρὰ σοφοῖν ἀνδροῖν ἀκοῦσαι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:896b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:896b.1.text#τίνα λόγων ἐμμέλειαν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:897.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:897.1.text#ἔπιτε δαΐαν ὁδόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:898.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:898.1.text#γλῶσσα μὲν γὰρ ἠγρίωται,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:899.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:899.1.text#λῆμα δ' οὐκ ἄτολμον ἀμφοῖν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:899b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:899b.1.text#οὐδ' ἀκίνητοι φρένες.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:900.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:900.1.text#προσδοκᾶν οὖν εἰκός ἐστι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:901.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:901.1.text#τὸν μὲν ἀστεῖόν τι λέξειν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:902.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:902.1.text#καὶ κατερρινημένον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:903.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:903.1.text#τὸν δ' ἀνασπῶντ' αὐτοπρέμνοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:903b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:903b.1.text#τοῖς λόγοισιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:904.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:904.1.text#ἐμπεσόντα συσκεδᾶν πολλὰς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:904b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:904b.1.text#ἀλινδήθρας ἐπῶν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:905.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:905.1.text#ἀλλ' ὡς τάχιστα χρὴ λέγειν· οὕτω δ' ὅπως ἐρεῖτον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:906.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:906.1.text#ἀστεῖα καὶ μήτ' εἰκόνας μήθ' οἷ' ἂν ἄλλος εἴποι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:907.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:907.1.text#καὶ μὴν ἐμαυτὸν μέν γε τὴν ποίησιν οἷός εἰμι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:908.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:908.1.text#ἐν τοῖσιν ὑστάτοις φράσω, τοῦτον δὲ πρῶτ' ἐλέγξω,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:909.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:909.1.text#ὡς ἦν ἀλαζὼν καὶ φέναξ οἵοις τε τοὺς θεατὰς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:910.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:910.1.text#ἐξηπάτα μώρους λαβὼν παρὰ Φρυνίχῳ τραφέντας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:911.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:911.1.text#πρώτιστα μὲν γὰρ ἕνα τιν' ἂν καθῖσεν ἐγκαλύψας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:912.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:912.1.text#Ἀχιλλέα τιν' ἢ Νιόβην, τὸ πρόσωπον οὐχὶ δεικνύς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:913.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:913.1.text#πρόσχημα τῆς τραγῳδίας, γρύζοντας οὐδὲ τουτί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:914.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:914.1.text#μὰ τὸν Δί' οὐ δῆθ'.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:914.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:914.2.text#ὁ δὲ χορός γ' ἤρειδεν ὁρμαθοὺς ἂν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:915.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:915.1.text#μελῶν ἐφεξῆς τέτταρας ξυνεχῶς ἄν οἱ δ' ἐσίγων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:916.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:916.1.text#ἐγὼ δ' ἔχαιρον τῇ σιωπῇ, καί με τοῦτ' ἔτερπεν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:917.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:917.1.text#οὐχ ἧττον ἢ νῦν οἱ λαλοῦντες.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:917.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:917.2.text#ἠλίθιος γὰρ ἦσθα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:918.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:918.1.text#σάφ' ἴσθι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:918.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:918.2.text#κἀμαυτῷ δοκῶ. τί δὲ ταῦτ' ἔδρασ' ὁ δεῖνα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:919.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:919.1.text#ὑπ' ἀλαζονείας, ἵν' ὁ θεατὴς προσδοκῶν καθοῖτο,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:920.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:920.1.text#ὁπόθ' ἡ Νιόβη τι φθέγξεται· τὸ δρᾶμα δ' ἂν διῄει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:921.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:921.1.text#ὢ παμπόνηρος, οἷ' ἄρ' ἐφενακιζόμην ὑπ' αὐτοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:922.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:922.1.text#τί σκορδινᾷ καὶ δυσφορεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:922.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:922.2.text#ὅτι αὐτὸν ἐξελέγχω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:923.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:923.1.text#κἄπειτ' ἐπειδὴ ταῦτα ληρήσειε καὶ τὸ δρᾶμα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:924.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:924.1.text#ἤδη μεσοίη, ῥήματ' ἂν βόεια δώδεκ' εἶπεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:925.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:925.1.text#ὀφρῦς ἔχοντα καὶ λόφους, δείν' ἄττα μορμορωπά,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:926.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:926.1.text#ἄγνωτα τοῖς θεωμένοις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:926.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:926.2.text#οἴμοι τάλας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:926.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:926.3.text#σιώπα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:927.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:927.1.text#σαφὲς δ' ἂν εἶπεν οὐδὲ ἕν—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:927.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:927.2.text#μὴ πρῖε τοὺς ὀδόντας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:928.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:928.1.text#ἀλλ' ἢ Σκαμάνδρους ἢ τάφρους ἢ 'π' ἀσπίδων ἐπόντας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:929.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:929.1.text#γρυπαιέτους χαλκηλάτους καὶ ῥήμαθ' ἱππόκρημνα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:930.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:930.1.text#ἃ ξυμβαλεῖν οὐ ῥᾴδι' ἦν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:930.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:930.2.text#νὴ τοὺς θεοὺς ἐγὼ γοῦν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:931.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:931.1.text#ἤδη ποτ' ἐν μακρῷ χρόνῳ νυκτὸς διηγρύπνησα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:932.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:932.1.text#τὸν ξουθὸν ἱππαλεκτρυόνα ζητῶν τίς ἐστιν ὄρνις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:933.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:933.1.text#σημεῖον ἐν ταῖς ναυσὶν ὦμαθέστατ' ἐνεγέγραπτο.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:934.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:934.1.text#ἐγὼ δὲ τὸν Φιλοξένου γ' ᾤμην Ἔρυξιν εἶναι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:935.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:935.1.text#εἶτ' ἐν τραγῳδίαις ἐχρῆν κἀλεκτρυόνα ποιῆσαι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:936.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:936.1.text#σὺ δ' ὦ θεοῖσιν ἐχθρὲ ποῖ' ἄττ' ἐστὶν ἅττ' ἐποίεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:937.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:937.1.text#οὐχ ἱππαλεκτρυόνας μὰ Δί' οὐδὲ τραγελάφους, ἅπερ σύ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:938.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:938.1.text#ἃν τοῖσι παραπετάσμασιν τοῖς Μηδικοῖς γράφουσιν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:939.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:939.1.text#ἀλλ' ὡς παρέλαβον τὴν τέχνην παρὰ σοῦ τὸ πρῶτον εὐθὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:940.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:940.1.text#οἰδοῦσαν ὑπὸ κομπασμάτων καὶ ῥημάτων ἐπαχθῶν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:941.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:941.1.text#ἴσχνανα μὲν πρώτιστον αὐτὴν καὶ τὸ βάρος ἀφεῖλον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:942.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:942.1.text#ἐπυλλίοις καὶ περιπάτοις καὶ τευτλίοισι λευκοῖς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:943.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:943.1.text#χυλὸν διδοὺς στωμυλμάτων ἀπὸ βιβλίων ἀπηθῶν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:944.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:944.1.text#εἶτ' ἀνέτρεφον μονῳδίαις—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:944.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:944.2.text#Κηφισοφῶντα μιγνύς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:945.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:945.1.text#εἶτ' οὐκ ἐλήρουν ὅ τι τύχοιμ' οὐδ' ἐμπεσὼν ἔφυρον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:946.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:946.1.text#ἀλλ' οὑξιὼν πρώτιστα μέν μοι τὸ γένος εἶπ' ἂν εὐθὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:947.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:947.1.text#τοῦ δράματος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:947.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:947.2.text#κρεῖττον γὰρ ἦν σοι νὴ Δί' ἢ τὸ σαυτοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:948.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:948.1.text#ἔπειτ' ἀπὸ τῶν πρώτων ἐπῶν οὐδὲν παρῆκ' ἂν ἀργόν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:949.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:949.1.text#ἀλλ' ἔλεγεν ἡ γυνή τέ μοι χὠ δοῦλος οὐδὲν ἧττον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:950.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:950.1.text#χὠ δεσπότης χἠ παρθένος χἠ γραῦς ἄν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:950.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:950.2.text#εἶτα δῆτα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:951.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:951.1.text#οὐκ ἀποθανεῖν σε ταῦτ' ἐχρῆν τολμῶντα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:951.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:951.2.text#μὰ τὸν Ἀπόλλω·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:952.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:952.1.text#δημοκρατικὸν γὰρ αὔτ' ἔδρων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:952.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:952.2.text#τοῦτο μὲν ἔασον ὦ τᾶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:953.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:953.1.text#οὐ σοὶ γάρ ἐστι περίπατος κάλλιστα περί γε τούτου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:954.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:954.1.text#ἔπειτα τουτουσὶ λαλεῖν ἐδίδαξα—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:954.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:954.2.text#φημὶ κἀγώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:955.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:955.1.text#ὡς πρὶν διδάξαι γ' ὤφελες μέσος διαρραγῆναι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:956.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:956.1.text#λεπτῶν τε κανόνων ἐσβολὰς ἐπῶν τε γωνιασμούς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:957.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:957.1.text#νοεῖν ὁρᾶν ξυνιέναι στρέφειν ἐρᾶν τεχνάζειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:958.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:958.1.text#κάχ' ὑποτοπεῖσθαι, περινοεῖν ἅπαντα—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:958.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:958.2.text#φημὶ κἀγώ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:959.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:959.1.text#οἰκεῖα πράγματ' εἰσάγων, οἷς χρώμεθ',οἷς ξύνεσμεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:960.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:960.1.text#ἐξ ὧν γ' ἂν ἐξηλεγχόμην· ξυνειδότες γὰρ οὗτοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:961.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:961.1.text#ἤλεγχον ἄν μου τὴν τέχνην· ἀλλ' οὐκ ἐκομπολάκουν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:962.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:962.1.text#ἀπὸ τοῦ φρονεῖν ἀποσπάσας, οὐδ' ἐξέπληττον αὐτούς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:963.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:963.1.text#Κύκνους ποιῶν καὶ Μέμνονας κωδωνοφαλαροπώλους.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:964.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:964.1.text#γνώσει δὲ τοὺς τούτου τε κἀμοὺς ἑκατέρου μαθητάς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:965.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:965.1.text#τουτουμενὶ Φορμίσιος Μεγαίνετός θ' ὁ Μανῆς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:966.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:966.1.text#σαλπιγγολογχυπηνάδαι, σαρκασμοπιτυοκάμπται,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:967.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:967.1.text#οὑμοὶ δὲ Κλειτοφῶν τε καὶ Θηραμένης ὁ κομψός.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:968.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:968.1.text#Θηραμένης; σοφός γ' ἀνὴρ καὶ δεινὸς ἐς τὰ πάντα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:969.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:969.1.text#ὃς ἢν κακοῖς που περιπέσῃ καὶ πλησίον παραστῇ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:970.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:970.1.text#πέπτωκεν ἔξω τῶν κακῶν, οὐ Χῖος ἀλλὰ Κεῖος. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:971.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:971.1.text#τοιαῦτα μέντοὐγὼ φρονεῖν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:972.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:972.1.text#τούτοισιν εἰσηγησάμην,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:973.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:973.1.text#λογισμὸν ἐνθεὶς τῇ τέχνῃ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:974.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:974.1.text#καὶ σκέψιν, ὥστ' ἤδη νοεὶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:975.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:975.1.text#ἅπαντα καὶ διειδέναι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:976.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:976.1.text#τά τ' ἄλλα καὶ τὰς οἰκίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:977.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:977.1.text#οἰκεῖν ἄμεινον ἢ πρὸ τοῦ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:978.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:978.1.text#κἀνασκοπεῖν, “πῶς τοῦτ' ἔχει;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:979.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:979.1.text#ποῦ μοι τοδί; τίς τοῦτ' ἔλαβε;”
urn:cts:greekLit:tlg0019.tlg009.fu.sp:980.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:980.1.text#νὴ τοὺς θεοὺς νῦν γοῦν Ἀθηναίων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:981.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:981.1.text#ἅπας τις εἰσιὼν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:982.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:982.1.text#κέκραγε πρὸς τοὺς οἰκέτας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:983.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:983.1.text#ζητεῖ τε, “ποῦ 'στιν ἡ χύτρα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:984.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:984.1.text#τίς τὴν κεφαλὴν ἀπεδήδοκεν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:985.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:985.1.text#τῆς μαινίδος; τὸ τρύβλιον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:986.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:986.1.text#τὸ περυσινὸν τέθνηκέ μοι·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:987.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:987.1.text#ποῦ τὸ σκόροδον τὸ χθιζινόν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:988.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:988.1.text#τίς τῆς ἐλάας παρέτραγεν;”
urn:cts:greekLit:tlg0019.tlg009.fu.sp:989.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:989.1.text#τέως δ' ἀβελτερώτατοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:990.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:990.1.text#κεχηνότες Μαμμάκυθοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:991.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:991.1.text#Μελιτίδαι καθῆντο. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:992.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:992.1.text#τάδε μὲν λεύσσεις φαίδιμ' Ἀχιλλεῦ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:993.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:993.1.text#σὺ δὲ τί φέρε πρὸς ταῦτα λέξεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:994.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:994.1.text#μόνον ὅπως […]
urn:cts:greekLit:tlg0019.tlg009.fu.sp:994b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:994b.1.text#μή σ' ὁ θυμὸς ἁρπάσας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:995.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:995.1.text#ἐκτὸς οἴσει τῶν ἐλαῶν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:996.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:996.1.text#δεινὰ γὰρ κατηγόρηκεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:997.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:997.1.text#ἀλλ' ὅπως ὦ γεννάδα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:998.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:998.1.text#μὴ πρὸς ὀργὴν ἀντιλέξεις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:999.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:999.1.text#ἀλλὰ συστείλας ἄκροισι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1000.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1000.1.text#χρώμενος τοῖς ἱστίοις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1001.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1001.1.text#εἶτα μᾶλλον μᾶλλον ἄξεις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1002.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1002.1.text#καὶ φυλάξεις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1003.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1003.1.text#ἡνίκ' ἂν τὸ πνεῦμα λεῖον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1003b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1003b.1.text#καὶ καθεστηκὸς λάβῃς.  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1004.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1004.1.text#ἀλλ' ὦ πρῶτος τῶν Ἑλλήνων πυργώσας ῥήματα σεμνὰ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1005.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1005.1.text#καὶ κοσμήσας τραγικὸν λῆρον, θαρρῶν τὸν κρουνὸν ἀφίει. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1006.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1006.1.text#θυμοῦμαι μὲν τῇ ξυντυχίᾳ, καὶ μου τὰ σπλάγχν' ἀγανακτεῖ, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1007.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1007.1.text#εἰ πρὸς τοῦτον δεῖ μ' ἀντιλέγειν· ἵνα μὴ φάσκῃ δ' ἀπορεῖν με, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1008.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1008.1.text#ἀπόκριναί μοι, τίνος οὕνεκα χρὴ θαυμάζειν ἄνδρα ποιητήν; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1009.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1009.1.text#δεξιότητος καὶ νουθεσίας, ὅτι βελτίους τε ποιοῦμεν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1010.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1010.1.text#τοὺς ἀνθρώπους ἐν ταῖς πόλεσιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1010.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1010.2.text#τοῦτ' οὖν εἰ μὴ πεποίηκας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1011.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1011.1.text#ἀλλ' ἐκ χρηστῶν καὶ γενναίων μοχθηροτάτους ἀπέδειξας, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1012.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1012.1.text#τί παθεῖν φήσεις ἄξιος εἶναι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1012.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1012.2.text#τεθνάναι· μὴ τοῦτον ἐρώτα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1013.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1013.1.text#σκέψαι τοίνυν οἵους αὐτοὺς παρ' ἐμοῦ παρεδέξατο πρῶτον, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1014.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1014.1.text#εἰ γενναίους καὶ τετραπήχεις, καὶ μὴ διαδρασιπολίτας, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1015.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1015.1.text#μηδ' ἀγοραίους μηδὲ κοβάλους ὥσπερ νῦν μηδὲ πανούργους, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1016.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1016.1.text#ἀλλὰ πνέοντας δόρυ καὶ λόγχας καὶ λευκολόφους τρυφαλείας 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1017.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1017.1.text#καὶ πήληκας καὶ κνημῖδας καὶ θυμοὺς ἑπταβοείους.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1018.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1018.1.text#καὶ δὴ χωρεῖ τουτὶ τὸ κακόν· κρανοποιῶν αὖ μ' ἐπιτρίψει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1019.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1019.1.text#καὶ τί σὺ δράσας οὕτως αὐτοὺς γενναίους ἐξεδίδαξας; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1020.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1020.1.text#Αἰσχύλε λέξον, μηδ' αὐθάδως σεμνυνόμενος χαλέπαινε. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1021.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1021.1.text#δρᾶμα ποιήσας Ἄρεως μεστόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1021.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1021.2.text#ποῖον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1021.3.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1021.3.text#τοὺς ἕπτ' ἐπὶ Θήβας·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1022.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1022.1.text#ὃ θεασάμενος πᾶς ἄν τις ἀνὴρ ἠράσθη δάιος εἶναι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1023.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1023.1.text#τουτὶ μέν σοι κακὸν εἴργασται· Θηβαίους γὰρ πεποίηκας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1024.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1024.1.text#ἀνδρειοτέρους ἐς τὸν πόλεμον, καὶ τούτου γ' οὕνεκα τύπτου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1025.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1025.1.text#ἀλλ' ὑμῖν αὔτ' ἐξῆν ἀσκεῖν, ἀλλ' οὐκ ἐπὶ τοῦτ' ἐτράπεσθε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1026.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1026.1.text#εἶτα διδάξας Πέρσας μετὰ τοῦτ' ἐπιθυμεῖν ἐξεδίδαξα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1027.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1027.1.text#νικᾶν ἀεὶ τοὺς ἀντιπάλους, κοσμήσας ἔργον ἄριστον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1028.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1028.1.text#ἐχάρην γοῦν, †ἡνίκ' ἤκουσα περὶ Δαρείου τεθνεῶτος,†
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1029.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1029.1.text#ὁ χορὸς δ' εὐθὺς τὼ χεῖρ' ὡδὶ συγκρούσας εἶπεν “ἰαυοῖ.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1030.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1030.1.text#ταῦτα γὰρ ἄνδρας χρὴ ποιητὰς ἀσκεῖν. σκέψαι γὰρ ἀπ' ἀρχῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1031.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1031.1.text#ὡς ὠφέλιμοι τῶν ποιητῶν οἱ γενναῖοι γεγένηνται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1032.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1032.1.text#Ὀρφεὺς μὲν γὰρ τελετάς θ' ἡμῖν κατέδειξε φόνων τ' ἀπέχεσθαι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1033.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1033.1.text#Μουσαῖος δ' ἐξακέσεις τε νόσων καὶ χρησμούς, Ἡσίοδος δὲ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1034.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1034.1.text#γῆς ἐργασίας, καρπῶν ὥρας, ἀρότους· ὁ δὲ θεῖος Ὅμηρος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1035.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1035.1.text#ἀπὸ τοῦ τιμὴν καὶ κλέος ἔσχεν πλὴν τοῦδ' ὅτι χρήστ' ἐδίδαξεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1036.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1036.1.text#τάξεις ἀρετὰς ὁπλίσεις ἀνδρῶν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1036.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1036.2.text#καὶ μὴν οὐ Παντακλέα γε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1037.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1037.1.text#ἐδίδαξεν ὅμως τὸν σκαιότατον· πρώην γοῦν, ἡνίκ' ἔπεμπεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1038.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1038.1.text#τὸ κράνος πρῶτον περιδησάμενος τὸν λόφον ἤμελλ' ἐπιδήσειν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1039.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1039.1.text#ἀλλ' ἄλλους τοι πολλοὺς ἀγαθούς, ὧν ἦν καὶ Λάμαχος ἥρως· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1040.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1040.1.text#ὅθεν ἡμὴ φρὴν ἀπομαξαμένη πολλὰς ἀρετὰς ἐποίησεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1041.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1041.1.text#Πατρόκλων, Τεύκρων θυμολεόντων, ἵν' ἐπαίροιμ' ἄνδρα πολίτην
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1042.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1042.1.text#ἀντεκτείνειν αὑτὸν τούτοις, ὁπόταν σάλπιγγος ἀκούσῃ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1043.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1043.1.text#ἀλλ' οὐ μὰ Δί' οὐ Φαίδρας ἐποίουν πόρνας οὐδὲ Σθενεβοίας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1044.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1044.1.text#οὐδ' οἶδ' οὐδεὶς ἥντιν' ἐρῶσαν πώποτ' ἐποίησα γυναῖκα. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1045.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1045.1.text#μὰ Δί' οὐ γὰρ ἐπῆν τῆς Ἀφροδίτης οὐδέν σοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1045.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1045.2.text#μηδέ γ' ἐπείη.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1046.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1046.1.text#ἀλλ' ἐπί τοι σοὶ καὶ τοῖς σοῖσιν πολλὴ πολλοῦ 'πικαθῆτο, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1047.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1047.1.text#ὥστε γε καὐτόν σε κατ' οὖν ἔβαλεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1047.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1047.2.text#νὴ τὸν Δία τοῦτό γέ τοι δή.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1048.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1048.1.text#ἃ γὰρ ἐς τὰς ἀλλοτρίας ἐποίεις, αὐτὸς τούτοισιν ἐπλήγης. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1049.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1049.1.text#καὶ τί βλάπτουσ' ὦ σχέτλι' ἀνδρῶν τὴν πόλιν ἁμαὶ Σθενέβοιαι; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1050.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1050.1.text#ὅτι γενναίας καὶ γενναίων ἀνδρῶν ἀλόχους ἀνέπεισας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1051.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1051.1.text#κώνεια πιεῖν αἰσχυνθείσας διὰ τοὺς σοὺς Βελλεροφόντας. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1052.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1052.1.text#πότερον δ' οὐκ ὄντα λόγον τοῦτον περὶ τῆς Φαίδρας ξυνέθηκα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1053.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1053.1.text#μὰ Δί' ἀλλ' ὄντ'· ἀλλ' ἀποκρύπτειν χρὴ τὸ πονηρὸν τόν γε ποιητήν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1054.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1054.1.text#καὶ μὴ παράγειν μηδὲ διδάσκειν. τοῖς μὲν γὰρ παιδαρίοισιν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1055.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1055.1.text#ἔστι διδάσκαλος ὅστις φράζει, τοῖσιν δ' ἡβῶσι ποιηταί. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1056.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1056.1.text#πάνυ δὴ δεῖ χρηστὰ λέγειν ἡμᾶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1056.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1056.2.text#ἢν οὖν σὺ λέγῃς Λυκαβηττοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1057.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1057.1.text#καὶ Παρνασσῶν ἡμῖν μεγέθη, τοῦτ' ἐστὶ τὸ χρηστὰ διδάσκειν, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1058.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1058.1.text#ὃν χρῆν φράζειν ἀνθρωπείως;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1058.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1058.2.text#ἀλλ' ὦ κακόδαιμον ἀνάγκη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1059.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1059.1.text#μεγάλων γνωμῶν καὶ διανοιῶν ἴσα καὶ τὰ ῥήματα τίκτειν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1060.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1060.1.text#κἄλλως εἰκὸς τοὺς ἡμιθέους τοῖς ῥήμασι μείζοσι χρῆσθαι· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1061.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1061.1.text#καὶ γὰρ τοῖς ἱματίοις ἡμῶν χρῶνται πολὺ σεμνοτέροισιν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1062.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1062.1.text#ἁμοῦ χρηστῶς καταδείξαντος διελυμήνω σύ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1062.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1062.2.text#τί δράσας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1063.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1063.1.text#πρῶτον μὲν τοὺς βασιλεύοντας ῥάκι' ἀμπισχών, ἵν' ἐλεινοὶ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1064.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1064.1.text#τοῖς ἀνθρώποις φαίνοιντ' εἶναι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1064.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1064.2.text#τοῦτ' οὖν ἔβλαψά τι δράσας;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1065.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1065.1.text#οὔκουν ἐθέλει γε τριηραρχεῖν πλουτῶν οὐδεὶς διὰ ταῦτα, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1066.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1066.1.text#ἀλλὰ ῥακίοις περιειλάμενος κλάει καὶ φησὶ πένεσθαι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1067.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1067.1.text#νὴ τὴν Δήμητρα χιτῶνά γ' ἔχων οὔλων ἐρίων ὑπένερθεν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1068.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1068.1.text#κἂν ταῦτα λέγων ἐξαπατήσῃ, παρὰ τοὺς ἰχθῦς ἀνέκυψεν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1069.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1069.1.text#εἶτ' αὖ λαλιὰν ἐπιτηδεῦσαι καὶ στωμυλίαν ἐδίδαξας, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1070.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1070.1.text#ἣ 'ξεκένωσεν τάς τε παλαίστρας καὶ τὰς πυγὰς ἐνέτριψεν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1071.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1071.1.text#τῶν μειρακίων στωμυλλομένων, καὶ τοὺς Παράλους ἀνέπεισεν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1072.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1072.1.text#ἀνταγορεύειν τοῖς ἄρχουσιν. καίτοι τότε γ' ἡνίκ' ἐγὼ 'ζων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1073.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1073.1.text#οὐκ ἠπίσταντ' ἀλλ' ἢ μᾶζαν καλέσαι καὶ “ῥυππαπαῖ” εἰπεῖν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1074.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1074.1.text#νὴ τὸν Ἀπόλλω, καὶ προσπαρδεῖν γ' ἐς τὸ στόμα τῷ θαλάμακι, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1075.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1075.1.text#καὶ μινθῶσαι τὸν ξύσσιτον κἀκβάς τινα λωποδυτῆσαι· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1076.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1076.1.text#νῦν δ' ἀντιλέγει κοὐκέτ' ἐλαύνων πλεῖ δευρὶ καὖθις ἐκεῖσε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1078.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1078.1.text#ποίων δὲ κακῶν οὐκ αἴτιός ἐστ';
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1079.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1079.1.text#οὐ προαγωγοὺς κατέδειξ' οὗτος,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1080.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1080.1.text#καὶ τικτούσας ἐν τοῖς ἱεροῖς, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1081.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1081.1.text#καὶ μιγνυμένας τοῖσιν ἀδελφοῖς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1082.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1082.1.text#καὶ φασκούσας οὐ ζῆν τὸ ζῆν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1083.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1083.1.text#κᾆτ' ἐκ τούτων ἡ πόλις ἡμῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1084.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1084.1.text#ὑπογραμματέων ἀνεμεστώθη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1085.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1085.1.text#καὶ βωμολόχων δημοπιθήκων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1086.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1086.1.text#ἐξαπατώντων τὸν δῆμον ἀεί,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1087.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1087.1.text#λαμπάδα δ' οὐδεὶς οἷός τε φέρειν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1088.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1088.1.text#ὑπ' ἀγυμνασίας ἔτι νυνί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1089.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1089.1.text#μὰ Δί' οὐ δῆθ', ὥστ' ἐπαφαυάνθην
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1090.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1090.1.text#Παναθηναίοισι γελῶν, ὅτε δὴ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1091.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1091.1.text#βραδὺς ἄνθρωπός τις ἔθει κύψας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1092.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1092.1.text#λευκὸς πίων ὑπολειπόμενος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1093.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1093.1.text#καὶ δεινὰ ποιῶν· κᾆθ' οἱ Κεραμῆς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1094.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1094.1.text#ἐν ταῖσι πύλαις παίουσ' αὐτοῦ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1095.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1095.1.text#γαστέρα πλευρὰς λαγόνας πυγήν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1096.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1096.1.text#ὁ δὲ τυπτόμενος ταῖσι πλατείαις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1097.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1097.1.text#ὑποπερδόμενος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1098.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1098.1.text#φυσῶν τὴν λαμπάδ' ἔφευγεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1099.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1099.1.text#μέγα τὸ πρᾶγμα, πολὺ τὸ νεῖκος, ἁδρὸς ὁ πόλεμος ἔρχεται. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1100.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1100.1.text#χαλεπὸν οὖν ἔργον διαιρεῖν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1101.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1101.1.text#ὅταν ὁ μὲν τείνῃ βιαίως,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1102.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1102.1.text#ὁ δ' ἐπαναστρέφειν δύνηται κἀπερείδεσθαι τορῶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1103.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1103.1.text#ἀλλὰ μὴ ν' ταὐτῷ κάθησθον·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1104.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1104.1.text#ἐσβολαὶ γάρ εἰσι πολλαὶ χἄτεραι σοφισμάτων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1105.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1105.1.text#ὅ τι περ οὖν ἔχετον ἐρίζειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1106.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1106.1.text#λέγετον ἔπιτον ἀνά τε δέρετον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1107.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1107.1.text#τά τε παλαιὰ καὶ τὰ καινά,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1108.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1108.1.text#κἀποκινδυνεύετον λεπτόν τι καὶ σοφὸν λέγειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1109.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1109.1.text#εἰ δὲ τοῦτο καταφοβεῖσθον, μή τις ἀμαθία προσῇ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1110.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1110.1.text#τοῖς θεωμένοισιν, ὡς τὰ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1111.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1111.1.text#λεπτὰ μὴ γνῶναι λεγόντοιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1112.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1112.1.text#μηδὲν ὀρρωδεῖτε τοῦθ'· ὡς οὐκέθ' οὕτω ταῦτ' ἔχει. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1113.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1113.1.text#ἐστρατευμένοι γάρ εἰσι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1114.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1114.1.text#βιβλίον τ' ἔχων ἕκαστος μανθάνει τὰ δεξιά· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1115.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1115.1.text#αἱ φύσεις τ' ἄλλως κράτισται, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1116.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1116.1.text#νῦν δὲ καὶ παρηκόνηνται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1117.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1117.1.text#μηδὲν οὖν δείσητον, ἀλλὰ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1118.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1118.1.text#πάντ' ἐπέξιτον θεατῶν γ' οὕνεχ' ὡς ὄντων σοφῶν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1119.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1119.1.text#καὶ μὴν ἐπ' αὐτοὺς τοὺς προλόγους σου τρέψομαι, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1120.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1120.1.text#ὅπως τὸ πρῶτον τῆς τραγῳδίας μέρος 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1121.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1121.1.text#πρώτιστον αὐτοῦ βασανιῶ τοῦ δεξιοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1122.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1122.1.text#ἀσαφὴς γὰρ ἦν ἐν τῇ φράσει τῶν πραγμάτων. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1123.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1123.1.text#καὶ ποῖον αὐτοῦ βασανιεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1123.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1123.2.text#πολλοὺς πάνυ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1124.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1124.1.text#πρῶτον δέ μοι τὸν ἐξ Ὀρεστείας λέγε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1125.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1125.1.text#ἄγε δὴ σιώπα πᾶς ἀνήρ. λέγ' Αἰσχύλε. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1126.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1126.1.text#“Ἑρμῆ χθόνιε πατρῷ' ἐποπτεύων κράτη,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1127.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1127.1.text#σωτὴρ γενοῦ μοι σύμμαχός τ' αἰτουμένῳ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1128.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1128.1.text#ἥκω γὰρ ἐς γῆν τήνδε καὶ κατέρχομαι.”
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1129.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1129.1.text#τούτων ἔχεις ψέγειν τι;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1129.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1129.2.text#πλεῖν ἢ δώδεκα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1130.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1130.1.text#ἀλλ' οὐδὲ πάντα ταῦτά γ' ἔστ' ἀλλ' ἢ τρία.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1131.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1131.1.text#ἔχει δ' ἕκαστον εἴκοσίν γ' ἁμαρτίας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1132.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1132.1.text#Αἰσχύλε παραινῶ σοι σιωπᾶν· εἰ δὲ μή,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1133.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1133.1.text#πρὸς τρισὶν ἰαμβείοισι προσοφείλων φανεῖ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1134.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1134.1.text#ἐγὼ σιωπῶ τῷδ';
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1134.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1134.2.text#ἐὰν πείθῃ γ' ἐμοί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1135.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1135.1.text#εὐθὺς γὰρ ἡμάρτηκεν οὐράνιόν γ' ὅσον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1136.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1136.1.text#ὁρᾷς ὅτι ληρεῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1136.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1136.2.text#ἀλλ' ὀλίγον γέ μοι μέλει.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1137.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1137.1.text#πῶς φῄς μ' ἁμαρτεῖν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1137.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1137.2.text#αὖθις ἐξ ἀρχῆς λέγε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1138.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1138.1.text# “Ἑρμῆ χθόνιε πατρῷ' ἐποπτεύων κράτη.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1139.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1139.1.text#οὔκουν Ὀρέστης τοῦτ' ἐπὶ τῷ τύμβῳ λέγει 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1140.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1140.1.text#τῷ τοῦ πατρὸς τεθνεῶτος;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1140.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1140.2.text#οὐκ ἄλλως λέγω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1141.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1141.1.text#πότερ' οὖν τὸν Ἑρμῆν, ὡς ὁ πατὴρ ἀπώλετο 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1142.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1142.1.text#αὐτοῦ βιαίως ἐκ γυναικείας χερὸς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1143.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1143.1.text#δόλοις λαθραίοις, ταῦτ' “ἐποπτεύειν” ἔφη; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1144.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1144.1.text#οὐ δῆτ' ἐκεῖνον, ἀλλὰ τὸν Ἐριούνιον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1145.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1145.1.text#Ἑρμῆν χθόνιον προσεῖπε, κἀδήλου λέγων 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1146.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1146.1.text#ὁτιὴ πατρῷον τοῦτο κέκτηται γέρας—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1147.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1147.1.text#ἔτι μεῖζον ἐξήμαρτες ἢ 'γὼ 'βουλόμην·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1148.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1148.1.text#εἰ γὰρ πατρῷον τὸ χθόνιον ἔχει γέρας—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1149.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1149.1.text#οὕτω γ' ἂν εἴη πρὸς πατρὸς τυμβωρύχος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1150.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1150.1.text#Διόνυσε πίνεις οἶνον οὐκ ἀνθοσμίαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1151.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1151.1.text#λέγ' ἕτερον αὐτῷ· σὺ δ' ἐπιτήρει τὸ βλάβος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1152.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1152.1.text#“σωτὴρ γενοῦ μοι σύμμαχός τ' αἰτουμένῳ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1153.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1153.1.text#ἥκω γὰρ ἐς γῆν τήνδε καὶ κατέρχομαι—”
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1154.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1154.1.text#δὶς ταὐτὸν ἡμῖν εἶπεν ὁ σοφὸς Αἰσχύλος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1155.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1155.1.text#πῶς δίς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1155.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1155.2.text#σκόπει τὸ ῥῆμ'· ἐγὼ δέ σοι φράσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1156.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1156.1.text# “ἥκω γὰρ ἐς γῆν,” φησί, “καὶ κατέρχομαι·” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1157.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1157.1.text# “ἥκω” δὲ ταὐτόν ἐστι τῷ “κατέρχομαι.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1158.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1158.1.text#νὴ τὸν Δί' ὥσπερ γ' εἴ τις εἴποι γείτονι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1159.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1159.1.text# “χρῆσον σὺ μάκτραν, εἰ δὲ βούλει, κάρδοπον.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1160.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1160.1.text#οὐ δῆτα τοῦτό γ' ὦ κατεστωμυλμένε 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1161.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1161.1.text#ἄνθρωπε ταὔτ' ἔστ', ἀλλ' ἄριστ' ἐπῶν ἔχον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1162.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1162.1.text#πῶς δή; δίδαξον γάρ με καθ' ὅ τι δὴ λέγεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1163.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1163.1.text# “ἐλθεῖν” μὲν ἐς γῆν ἔσθ' ὅτῳ μετῇ πάτρας· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1164.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1164.1.text#χωρὶς γὰρ ἄλλης συμφορᾶς ἐλήλυθεν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1165.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1165.1.text#φεύγων δ' ἀνὴρ “ἥκει” τε καὶ “κατέρχεται.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1166.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1166.1.text#εὖ νὴ τὸν Ἀπόλλω. τί σὺ λέγεις Εὐριπίδη; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1167.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1167.1.text#οὐ φημὶ τὸν Ὀρέστην κατελθεῖν οἴκαδε·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1168.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1168.1.text#λάθρᾳ γὰρ ἦλθεν οὐ πιθὼν τοὺς κυρίους. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1169.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1169.1.text#εὖ νὴ τὸν Ἑρμῆν· ὅ τι λέγεις δ' οὐ μανθάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1170.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1170.1.text#πέραινε τοίνυν ἕτερον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1170.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1170.2.text#ἴθι πέραινε σὺ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1171.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1171.1.text#Αἰσχύλ' ἀνύσας· σὺ δ' ἐς τὸ κακὸν ἀπόβλεπε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1172.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1172.1.text#“τύμβου δ' ἐπ' ὄχθῳ τῷδε κηρύσσω πατρὶ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1173.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1173.1.text#κλύειν ἀκοῦσαι.”
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1173.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1173.2.text#τοῦθ' ἕτερον αὖθις λέγει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1174.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1174.1.text# “κλύειν ἀκοῦσαι,” ταὐτὸν ὂν σαφέστατα. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1175.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1175.1.text#τεθνηκόσιν γὰρ ἔλεγεν ὦ μόχθηρε σύ, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1176.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1176.1.text#οἷς οὐδὲ τρὶς λέγοντες ἐξικνούμεθα. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1177.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1177.1.text#σὺ δὲ πῶς ἐποίεις τοὺς προλόγους;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1177.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1177.2.text#ἐγὼ φράσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1178.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1178.1.text#κἄν που δὶς εἴπω ταὐτόν, ἢ στοιβὴν ἴδῃς 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1179.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1179.1.text#ἐνοῦσαν ἔξω τοῦ λόγου, κατάπτυσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1180.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1180.1.text#ἴθι δὴ λέγ'· οὐ γάρ μοὔστιν ἀλλ' ἀκουστέα 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1181.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1181.1.text#τῶν σῶν προλόγων τῆς ὀρθότητος τῶν ἐπῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1182.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1182.1.text# “ἦν Οἰδίπους τὸ πρῶτον εὐδαίμων ἀνήρ” —
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1183.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1183.1.text#μὰ τὸν Δί' οὐ δῆτ', ἀλλὰ κακοδαίμων φύσει, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1184.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1184.1.text#ὅντινά γε πρὶν φῦναι μὲν Ἁπόλλων ἔφη
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1185.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1185.1.text#ἀποκτενεῖν τὸν πατέρα, πρὶν καὶ γεγονέναι· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1186.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1186.1.text#πῶς οὗτος ἦν τὸ πρῶτον εὐδαίμων ἀνήρ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1187.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1187.1.text# “εἶτ' ἐγένετ' αὖθις ἀθλιώτατος βροτῶν.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1188.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1188.1.text#μὰ τὸν Δί' οὐ δῆτ', οὐ μὲν οὖν ἐπαύσατο. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1189.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1189.1.text#πῶς γάρ; ὅτε δὴ πρῶτον μὲν αὐτὸν γενόμενον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1190.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1190.1.text#χειμῶνος ὄντος ἐξέθεσαν ἐν ὀστράκῳ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1191.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1191.1.text#ἵνα μὴ 'κτραφεὶς γένοιτο τοῦ πατρὸς φονεύς·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1192.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1192.1.text#εἶθ' ὡς Πόλυβον ἤρρησεν οἰδῶν τὼ πόδε·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1193.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1193.1.text#ἔπειτα γραῦν ἔγημεν αὐτὸς ὢν νέος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1194.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1194.1.text#καὶ πρός γε τούτοις τὴν ἑαυτοῦ μητέρα·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1195.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1195.1.text#εἶτ' ἐξετύφλωσεν αὑτόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1195.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1195.2.text#εὐδαίμων ἄρ' ἦν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1196.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1196.1.text#εἰ κἀστρατήγησέν γε μετ' Ἐρασινίδου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1197.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1197.1.text#ληρεῖς· ἐγὼ δὲ τοὺς προλόγους καλοὺς ποιῶ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1198.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1198.1.text#καὶ μὴν μὰ τὸν Δί' οὐ κατ' ἔπος γέ σου κνίσω 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1199.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1199.1.text#τὸ ῥῆμ' ἕκαστον, ἀλλὰ σὺν τοῖσιν θεοῖς 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1200.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1200.1.text#ἀπὸ ληκυθίου σου τοὺς προλόγους διαφθερῶ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1201.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1201.1.text#ἀπὸ ληκυθίου σὺ τοὺς ἐμούς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1201.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1201.2.text#ἑνὸς μόνου.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1202.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1202.1.text#ποιεῖς γὰρ οὕτως ὥστ' ἐναρμόττειν ἅπαν, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1203.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1203.1.text#καὶ κῳδάριον καὶ ληκύθιον καὶ θύλακον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1204.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1204.1.text#ἐν τοῖς ἰαμβείοισι. δείξω δ' αὐτίκα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1205.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1205.1.text#ἰδού, σὺ δείξεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1205.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1205.2.text#φημί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1205.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1205.3.text#καὶ δὴ χρὴ λέγειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1206.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1206.1.text#Αἴγυπτος, ὡς ὁ πλεῖστος ἔσπαρται λόγος,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1207.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1207.1.text#ξὺν παισὶ πεντήκοντα ναυτίλῳ πλάτῃ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1208.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1208.1.text#Ἄργος κατασχών—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1208.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1208.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1209.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1209.1.text#τουτὶ τί ἦν τὸ ληκύθιον; οὐ κλαύσεται; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1210.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1210.1.text#λέγ' ἕτερον αὐτῷ πρόλογον, ἵνα καὶ γνῶ πάλιν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1211.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1211.1.text#“Διόνυσος, ὃς θύρσοισι καὶ νεβρῶν δοραῖς 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1212.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1212.1.text#καθαπτὸς ἐν πεύκαισι Παρνασσὸν κάτα 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1213.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1213.1.text#πηδᾷ χορεύων”—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1213.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1213.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1214.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1214.1.text#οἴμοι πεπλήγμεθ' αὖθις ὑπὸ τῆς ληκύθου. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1215.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1215.1.text#ἀλλ' οὐδὲν ἔσται πρᾶγμα· πρὸς γὰρ τουτονὶ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1216.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1216.1.text#τὸν πρόλογον οὐχ ἕξει προσάψαι λήκυθον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1217.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1217.1.text#“οὐκ ἔστιν ὅστις πάντ' ἀνὴρ εὐδαιμονεῖ· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1218.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1218.1.text#ἢ γὰρ πεφυκὼς ἐσθλὸς οὐκ ἔχει βίον, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1219.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1219.1.text#ἢ δυσγενὴς ὤν”—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1219.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1219.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1220.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1220.1.text#Εὐριπίδη—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1220.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1220.2.text#τί ἔσθ';
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1220.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1220.3.text#ὑφέσθαι μοι δοκεῖ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1221.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1221.1.text#τὸ ληκύθιον γὰρ τοῦτο πνευσεῖται πολύ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1222.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1222.1.text#οὐδ' ἂν μὰ τὴν Δήμητρα φροντίσαιμί γε· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1223.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1223.1.text#νυνὶ γὰρ αὐτοῦ τοῦτό γ' ἐκκεκόψεται. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1224.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1224.1.text#ἴθι δὴ λέγ' ἕτερον κἀπέχου τῆς ληκύθου. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1225.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1225.1.text#“Σιδώνιόν ποτ' ἄστυ Κάδμος ἐκλιπὼν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1226.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1226.1.text#Ἀγήνορος παῖσ'—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1226.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1226.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1227.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1227.1.text#ὦ δαιμόνι' ἀνδρῶν ἀποπρίω τὴν λήκυθον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1228.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1228.1.text#ἵνα μὴ διακναίσῃ τοὺς προλόγους ἡμῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1228.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1228.2.text#τὸ τί; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1229.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1229.1.text#ἐγὼ πρίωμαι τῷδ';
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1229.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1229.2.text#ἐὰν πείθῃ γ' ἐμοί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1230.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1230.1.text#οὐ δῆτ', ἐπεὶ πολλοὺς προλόγους ἕξω λέγειν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1231.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1231.1.text#ἵν' οὗτος οὐχ ἕξει προσάψαι ληκύθιον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1232.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1232.1.text#“Πέλοψ ὁ Ταντάλειος ἐς Πῖσαν μολὼν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1233.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1233.1.text#θοαῖσιν ἵπποισ'—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1233.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1233.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1234.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1234.1.text#ὁρᾷς, προσῆψεν αὖθις αὖ τὴν λήκυθον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1235.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1235.1.text#ἀλλ' ὦγάθ' ἔτι καὶ νῦν ἀπόδος πάσῃ τέχνῃ· 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1236.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1236.1.text#λήψει γὰρ ὀβολοῦ πάνυ καλήν τε κἀγαθήν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1237.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1237.1.text#μὰ τὸν Δί' οὔπω γ'· ἔτι γὰρ εἰσί μοι συχνοί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1238.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1238.1.text# “Οἰνεύς ποτ' ἐκ γῆς” —
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1238.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1238.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1239.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1239.1.text#ἔασον εἰπεῖν πρῶθ' ὅλον με τὸν στίχον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1240.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1240.1.text#“Οἰνεύς ποτ' ἐκ γῆς πολύμετρον λαβὼν στάχυν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1241.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1241.1.text#θύων ἀπαρχάσ'—
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1241.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1241.2.text#ληκύθιον ἀπώλεσεν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1242.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1242.1.text#μεταξὺ θύων; καὶ τίς αὔθ' ὑφείλετο; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1243.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1243.1.text#ἔα αὐτὸν ὦ τᾶν· πρὸς τοδὶ γὰρ εἰπάτω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1244.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1244.1.text# “Ζεύς, ὡς λέλεκται τῆς ἀληθείας ὕπο” — 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1245.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1245.1.text#ἀπολεῖ σ'· ἐρεῖ γάρ, “ληκύθιον ἀπώλεσεν.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1246.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1246.1.text#τὸ ληκύθιον γὰρ τοῦτ' ἐπὶ τοῖς προλόγοισί σου 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1247.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1247.1.text#ὥσπερ τὰ σῦκ' ἐπὶ τοῖσιν ὀφθαλμοῖς ἔφυ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1248.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1248.1.text#ἀλλ' ἐς τὰ μέλη πρὸς τῶν θεῶν αὐτοῦ τραποῦ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1249.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1249.1.text#καὶ μὴν ἔχω γ' οἷς αὐτὸν ἀποδείξω κακὸν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1250.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1250.1.text#μελοποιὸν ὄντα καὶ ποιοῦντα ταὔτ' ἀεί. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1251.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1251.1.text#τί ποτε πρᾶγμα γενήσεται;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1252.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1252.1.text#φροντίζειν γὰρ ἔγωγ' ἔχω,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1253.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1253.1.text#τίν' ἄρα μέμψιν ἐποίσει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1254.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1254.1.text#ἀνδρὶ τῷ πολὺ πλεῖστα δὴ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1255.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1255.1.text#καὶ κάλλιστα μέλη ποιήσαντι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1256.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1256.1.text#τῶν μέχρι νυνί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1257.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1257.1.text#θαυμάζω γὰρ ἔγωγ' ὅπῃ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1258.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1258.1.text#μέμψεταί ποτε τοῦτον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1259.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1259.1.text#τὸν Βακχεῖον ἄνακτα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1260.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1260.1.text#καὶ δέδοιχ' ὑπὲρ αὐτοῦ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1261.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1261.1.text#πάνυ γε μέλη θαυμαστά· δείξει δὴ τάχα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1262.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1262.1.text#εἰς ἓν γὰρ αὐτοῦ πάντα τὰ μέλη ξυντεμῶ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1263.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1263.1.text#καὶ μὴν λογιοῦμαι ταῦτα τῶν ψήφων λαβών·ʽδιαύλιον προσαυλεῖ τισ̓ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1264.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1264.1.text#Φθιῶτ' Ἀχιλλεῦ, τί ποτ' ἀνδροδάικτον ἀκούων 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1265.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1265.1.text#ἰὴ κόπον οὐ πελάθεις ἐπ' ἀρωγάν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1266.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1266.1.text#Ἑρμᾶν μὲν πρόγονον τίομεν γένος οἱ περὶ λίμναν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1267.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1267.1.text#ἰὴ κόπον οὐ πελάθεις ἐπ' ἀρωγάν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1268.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1268.1.text#δύο σοὶ κόπω Αἰσχύλε τούτω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1270.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1270.1.text#κύδιστ' Ἀχαιῶν Ἀτρέως πολυκοίρανε μάνθανέ μου παῖ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1271.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1271.1.text#ἰὴ κόπον οὐ πελάθεις ἐπ' ἀρωγάν; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1272.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1272.1.text#τρίτος ᾠσχύλε σοὶ κόπος οὗτος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1274.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1274.1.text#εὐφαμεῖτε· μελισσονόμοι δόμον Ἀρτέμιδος πέλας οἴγειν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1275.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1275.1.text#ἰὴ κόπον οὐ πελάθεις ἐπ' ἀρωγάν; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1276.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1276.1.text#κύριός εἰμι θροεῖν ὅδιον κράτος αἴσιον ἀνδρῶν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1277.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1277.1.text#ἰὴ κόπον οὐ πελάθεις ἐπ' ἀρωγάν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1278.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1278.1.text#ὦ Ζεῦ βασιλεῦ τὸ χρῆμα τῶν κόπων ὅσον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1279.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1279.1.text#ἐγὼ μὲν οὖν ἐς τὸ βαλανεῖον βούλομαι·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1280.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1280.1.text#ὑπὸ τῶν κόπων γὰρ τὼ νεφρὼ βουβωνιῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1281.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1281.1.text#μὴ πρίν γ' ἂν ἀκούσῃς χἀτέραν στάσιν μελῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1282.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1282.1.text#ἐκ τῶν κιθαρῳδικῶν νόμων εἰργασμένην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1283.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1283.1.text#ἴθι δὴ πέραινε, καὶ κόπον μὴ προστίθει. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1285.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1285.1.text#ὅπως Ἀχαιῶν δίθρονον κράτος, Ἑλλάδος ἥβας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1286.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1286.1.text#τοφλαττοθρατ τοφλαττοθρατ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1287.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1287.1.text#Σφίγγα δυσαμεριᾶν πρύτανιν κύνα, πέμπει, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1288.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1288.1.text#τοφλαττοθρατ τοφλαττοθρατ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1289.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1289.1.text#σὺν δορὶ καὶ χερὶ πράκτορι θούριος ὄρνις, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1290.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1290.1.text#τοφλαττοθρατ τοφλαττοθρατ, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1291.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1291.1.text#κυρεῖν παρασχὼν ἰταμαῖς κυσὶν ἀεροφοίτοις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1292.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1292.1.text#τοφλαττοθρατ τοφλαττοθρατ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1293.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1293.1.text#τὸ συγκλινές τ' ἐπ' Αἴαντι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1295.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1295.1.text#τοφλαττοθρατ τοφλαττοθρατ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1296.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1296.1.text#τί τὸ “φλαττοθρατ” τοῦτ' ἐστίν; ἐκ Μαραθῶνος ἢ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1297.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1297.1.text#πόθεν συνέλεξας ἱμονιοστρόφου μέλη; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1298.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1298.1.text#ἀλλ' οὖν ἐγὼ μὲν ἐς τὸ καλὸν ἐκ τοῦ καλοῦ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1299.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1299.1.text#ἤνεγκον αὔθ', ἵνα μὴ τὸν αὐτὸν Φρυνίχῳ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1300.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1300.1.text#λειμῶνα Μουσῶν ἱερὸν ὀφθείην δρέπων·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1301.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1301.1.text#οὗτος δ' ἀπὸ πάντων †μὲν φέρει, πορνιδίων†,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1302.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1302.1.text#σκολίων Μελήτου, Καρικῶν αὐλημάτων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1303.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1303.1.text#θρήνων, χορειῶν. τάχα δὲ δηλωθήσεται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1304.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1304.1.text#ἐνεγκάτω τις τὸ λύριον. καίτοι τί δεῖ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1305.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1305.1.text#λύρας ἐπὶ τούτων; ποῦ 'στιν ἡ τοῖς ὀστράκοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1306.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1306.1.text#αὕτη κροτοῦσα; δεῦρο Μοῦσ' Εὐριπίδου, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1307.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1307.1.text#πρὸς ἥνπερ ἐπιτήδεια ταῦτ' ᾄδειν μέλη. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1308.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1308.1.text#αὕτη ποθ' ἡ Μοῦσ' οὐκ ἐλεσβίαζεν, οὔ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1309.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1309.1.text#ἀλκυόνες, αἳ παρ' ἀενάοις θαλάσσης 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1310.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1310.1.text#κύμασι στωμύλλετε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1311.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1311.1.text#τέγγουσαι νοτίοις πτερῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1312.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1312.1.text#ῥανίσι χρόα δροσιζόμεναι·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1313.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1313.1.text#αἵ θ' ὑπωρόφιοι κατὰ γωνίας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1314.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1314.1.text#εἱειειειλίσσετε δακτύλοις φάλαγγες
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1315.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1315.1.text#ἱστόπονα πηνίσματα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1316.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1316.1.text#κερκίδος ἀοιδοῦ μελέτας,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1317.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1317.1.text#ἵν' ὁ φίλαυλος ἔπαλλε δελφὶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1318.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1318.1.text#πρῴραις κυανεμβόλοις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1319.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1319.1.text#μαντεῖα καὶ σταδίους,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1320.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1320.1.text#οἰνάνθας γάνος ἀμπέλου,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1321.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1321.1.text#βότρυος ἕλικα παυσίπονον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1322.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1322.1.text#περίβαλλ' ὦ τέκνον ὠλένας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1323.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1323.1.text#ὁρᾷς τὸν πόδα τοῦτον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1323.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1323.2.text#ὁρῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1324.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1324.1.text#τί δαί; τοῦτον ὁρᾷς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1324.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1324.2.text#ὁρῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1325.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1325.1.text#τοιαυτὶ μέντοι σὺ ποιῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1326.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1326.1.text#τολμᾷς τἀμὰ μέλη ψέγειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1327.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1327.1.text#ἀνὰ τὸ δωδεκαμήχανον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1328.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1328.1.text#Κυρήνης μελοποιῶν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1329.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1329.1.text#τὰ μὲν μέλη σου ταῦτα· βούλομαι δ' ἔτι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1330.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1330.1.text#τὸν τῶν μονῳδιῶν διεξελθεῖν τρόπον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1331.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1331.1.text#ὦ νυκτὸς κελαινοφαὴς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1331b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1331b.1.text#ὄρφνα, τίνα μοι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1332.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1332.1.text#δύστανον ὄνειρον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1332b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1332b.1.text#πέμπεις ἐξ ἀφανοῦς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1333.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1333.1.text#Ἀίδα πρόμολον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1334.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1334.1.text#ψυχὰν ἄψυχον ἔχοντα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1335.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1335.1.text#μελαίνας Νυκτὸς παῖδα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1336.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1336.1.text#φρικώδη δεινὰν ὄψιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1336b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1336b.1.text#μελανονεκυείμονα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1337.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1337.1.text#φόνια φόνια δερκόμενον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1337b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1337b.1.text#μεγάλους ὄνυχας ἔχοντα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1338.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1338.1.text#ἀλλά μοι ἀμφίπολοι λύχνον ἅψατε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1339.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1339.1.text#κάλπισί τ' ἐκ ποταμῶν δρόσον ἄρατε, θέρμετε δ' ὕδωρ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1340.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1340.1.text#ὡς ἂν θεῖον ὄνειρον ἀποκλύσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1340b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1340b.1.text#ἰὼ πόντιε δαῖμον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1341.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1341.1.text#τοῦτ' ἐκεῖν'· ἰὼ ξύνοικοι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1342.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1342.1.text#τάδε τέρα θεάσασθε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1343.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1343.1.text#τὸν ἀλεκτρυόνα μου συναρπάσασα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1343b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1343b.1.text#φρούδη Γλύκη.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1344.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1344.1.text#Νύμφαι ὀρεσσίγονοι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1345.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1345.1.text#ὦ Μανία ξύλλαβε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1346.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1346.1.text#ἐγὼ δ' ἁ τάλαινα προσέχουσ' ἔτυχον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1347.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1347.1.text#ἐμαυτῆς ἔργοισι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1348.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1348.1.text#λίνου μεστὸν ἄτρακτον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1349.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1349.1.text#εἱειειειλίσσουσα χεροῖν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1349b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1349b.1.text#κλωστῆρα ποιοῦσ', ὅπως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1350.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1350.1.text#κνεφαῖος εἰς ἀγορὰν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1351.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1351.1.text#φέρουσ' ἀποδοίμαν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1351b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1351b.1.text#ὁ δ' ἀνέπτατ' ἀνέπτατ' ἐς αἰθέρα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1352.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1352.1.text#κουφοτάταις πτερύγων ἀκμαῖς·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1353.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1353.1.text#ἐμοὶ δ' ἄχε' ἄχεα κατέλιπε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1354.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1354.1.text#δάκρυα δάκρυά τ' ἀπ' ὀμμάτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1355.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1355.1.text#ἔβαλον ἔβαλον ἁ τλάμων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1356.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1356.1.text#ἀλλ' ὦ Κρῆτες, Ἴδας τέκνα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1357.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1357.1.text#τὰ τόξα λαβόντες ἐπαμύνατε,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1358.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1358.1.text#τὰ κῶλά τ' ἀμπάλλετε κυκλούμενοι τὴν οἰκίαν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1359.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1359.1.text#ἅμα δὲ Δίκτυννα παῖς Ἄρτεμις καλὰ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1360.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1360.1.text#τὰς κυνίσκας ἔχουσ' ἐλθέτω διὰ δόμων πανταχῇ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1361.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1361.1.text#σὺ δ' ὦ Διὸς διπύρους ἀνέχουσα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1362.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1362.1.text#λαμπάδας ὀξυτάτας χεροῖν Ἑκάτα παράφηνον 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1363.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1363.1.text#ἐς Γλύκης, ὅπως ἂν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1363b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1363b.1.text#εἰσελθοῦσα φωράσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1364.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1364.1.text#παύσασθον ἤδη τῶν μελῶν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1364.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1364.2.text#κἄμοιγ' ἅλις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1365.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1365.1.text#ἐπὶ τὸν σταθμὸν γὰρ αὐτὸν ἀγαγεῖν βούλομαι, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1366.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1366.1.text#ὅπερ ἐξελέγξει τὴν ποίησιν νῷν μόνον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1367.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1367.1.text#τὸ γὰρ βάρος νὼ βασανιεῖ τῶν ῥημάτων.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1368.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1368.1.text#ἴτε δεῦρό νυν, εἴπερ γε δεῖ καὶ τοῦτό με
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1369.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1369.1.text#ἀνδρῶν ποιητῶν τυροπωλῆσαι τέχνην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1370.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1370.1.text#ἐπίπονοί γ' οἱ δεξιοί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1371.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1371.1.text#τόδε γὰρ ἕτερον αὖ τέρας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1372.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1372.1.text#νεοχμόν, ἀτοπίας πλέων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1373.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1373.1.text#ὃ τίς ἂν ἐπενόησεν ἄλλος;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1373b.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1373b.1.text#[…]
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1374.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1374.1.text#μὰ τὸν ἐγὼ μὲν οὐδ' ἂν εἴ τις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1375.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1375.1.text#ἔλεγέ μοι τῶν ἐπιτυχόντων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1376.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1376.1.text#ἐπιθόμην, ἀλλ' ᾠόμην ἂν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1377.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1377.1.text#αὐτὸν αὐτὰ ληρεῖν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1378.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1378.1.text#ἴθι δὴ παρίστασθον παρὰ τὼ πλάστιγγ',
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1378.2.speaker#Αἰσχύλος καὶ Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1378.2.text#ἰδού.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1379.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1379.1.text#καὶ λαβομένω τὸ ῥῆμ' ἑκάτερος εἴπατον,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1380.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1380.1.text#καὶ μὴ μεθῆσθον, πρὶν ἂν ἐγὼ σφῷν κοκκύσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1381.1.speaker#Αἰσχύλος καὶ Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1381.1.text#ἐχόμεθα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1381.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1381.2.text#τοὔπος νῦν λέγετον ἐς τὸν σταθμόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1382.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1382.1.text# “εἴθ' ὤφελ' Ἀργοῦς μὴ διαπτάσθαι σκάφος.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1383.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1383.1.text# “Σπερχειὲ ποταμὲ βουνόμοι τ' ἐπιστροφαί.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1384.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1384.1.text#κόκκυ, μέθεσθε· καὶ πολύ γε κατωτέρω
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1385.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1385.1.text#χωρεῖ τὸ τοῦδε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1385.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1385.2.text#καὶ τί ποτ' ἐστὶ ταἴτιον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1386.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1386.1.text#ὅτι εἰσέθηκε ποταμόν, ἐριοπωλικῶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1387.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1387.1.text#ὑγρὸν ποιήσας τοὔπος ὥσπερ τἄρια,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1388.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1388.1.text#σὺ δ' εἰσέθηκας τοὔπος ἐπτερωμένον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1389.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1389.1.text#ἀλλ' ἕτερον εἰπάτω τι κἀντιστησάτω. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1390.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1390.1.text#λάβεσθε τοίνυν αὖθις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1390.2.speaker#Αἰσχύλος καὶ Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1390.2.text#ἢν ἰδού.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1390.3.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1390.3.text#λέγε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1391.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1391.1.text# “οὐκ ἔστι Πειθοῦς ἱερὸν ἄλλο πλὴν λόγος.”  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1392.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1392.1.text# “μόνος θεῶν γὰρ Θάνατος οὐ δώρων ἐρᾷ.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1393.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1393.1.text#μέθεσθε μέθεσθε· καὶ τὸ τοῦδέ γ' αὖ ῥέπει·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1394.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1394.1.text#θάνατον γὰρ εἰσέθηκε βαρύτατον κακόν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1395.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1395.1.text#ἐγὼ δὲ πειθώ γ' ἔπος ἄριστ' εἰρημένον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1396.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1396.1.text#πειθὼ δὲ κοῦφόν ἐστι καὶ νοῦν οὐκ ἔχον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1397.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1397.1.text#ἀλλ' ἕτερον αὖ ζήτει τι τῶν βαρυστάθμων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1398.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1398.1.text#ὅ τι σοι καθέλξει, καρτερόν τε καὶ μέγα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1399.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1399.1.text#φέρε ποῦ τοιοῦτον δῆτά μοὐστί; ποῦ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1399.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1399.2.text#φράσω·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1400.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1400.1.text# “βέβληκ' Ἀχιλλεὺς δύο κύβω καὶ τέτταρα.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1401.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1401.1.text#λέγοιτ' ἄν, ὡς αὕτη 'στὶ λοιπὴ σφῷν στάσις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1402.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1402.1.text# “σιδηροβριθές τ' ἔλαβε δεξιᾷ ξύλον.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1403.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1403.1.text# “ἐφ' ἅρματος γὰρ ἅρμα καὶ νεκρῷ νεκρός.” 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1404.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1404.1.text#ἐξηπάτηκεν αὖ σὲ καὶ νῦν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1404.2.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1404.2.text#τῷ τρόπῳ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1405.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1405.1.text#δύ' ἅρματ' εἰσέθηκε καὶ νεκρὼ δύο,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1406.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1406.1.text#οὓς οὐκ ἂν ἄραιντ' οὐδ' ἑκατὸν Αἰγύπτιοι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1407.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1407.1.text#καὶ μηκέτ' ἔμοιγε κατ' ἔπος, ἀλλ' ἐς τὸν σταθμὸν 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1408.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1408.1.text#αὐτὸς τὰ παιδί' ἡ γυνὴ Κηφισοφῶν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1409.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1409.1.text#ἐμβὰς καθήσθω, συλλαβὼν τὰ βιβλία·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1410.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1410.1.text#ἐγὼ δὲ δύ' ἔπη τῶν ἐμῶν ἐρῶ μόνον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1411.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1411.1.text#ἅνδρες φίλοι, κἀγὼ μὲν αὐτοὺς οὐ κρινῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1412.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1412.1.text#οὐ γὰρ δι' ἔχθρας οὐδετέρῳ γενήσομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1413.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1413.1.text#τὸν μὲν γὰρ ἡγοῦμαι σοφὸν τῷ δ' ἥδομαι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1414.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1414.1.text#οὐδὲν ἄρα πράξεις ὧνπερ ἦλθες οὕνεκα; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1415.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1415.1.text#ἐὰν δὲ κρίνω;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1415.2.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1415.2.text#τὸν ἕτερον λαβὼν ἄπει,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1416.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1416.1.text#ὁπότερον ἂν κρίνῃς, ἵν' ἔλθῃς μὴ μάτην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1417.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1417.1.text#εὐδαιμονοίης. φέρε πύθεσθέ μου ταδί.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1418.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1418.1.text#ἐγὼ κατῆλθον ἐπὶ ποιητήν. τοῦ χάριν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1419.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1419.1.text#ἵν' ἡ πόλις σωθεῖσα τοὺς χοροὺς ἄγῃ. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1420.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1420.1.text#ὁπότερος οὖν ἂν τῇ πόλει παραινέσῃ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1421.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1421.1.text#μᾶλλόν τι χρηστόν, τοῦτον ἄξειν μοι δοκῶ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1422.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1422.1.text#πρῶτον μὲν οὖν περὶ Ἀλκιβιάδου τίν' ἔχετον 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1423.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1423.1.text#γνώμην ἑκάτερος; ἡ πόλις γὰρ δυστοκεῖ.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1424.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1424.1.text#ἔχει δὲ περὶ αὐτοῦ τίνα γνώμην;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1424.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1424.2.text#τίνα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1425.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1425.1.text#ποθεῖ μέν, ἐχθαίρει δέ, βούλεται δ' ἔχειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1426.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1426.1.text#ἀλλ' ὅ τι νοεῖτον εἴπατον τούτου πέρι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1427.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1427.1.text#μισῶ πολίτην, ὅστις ὠφελεῖν πάτραν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1428.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1428.1.text#βραδὺς πέφυκε μεγάλα δὲ βλάπτειν ταχύς,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1429.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1429.1.text#καὶ πόριμον αὑτῷ τῇ πόλει δ' ἀμήχανον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1430.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1430.1.text#εὖ γ' ὦ Πόσειδον· σὺ δὲ τίνα γνώμην ἔχεις; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1431.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1431.1.text#οὐ χρὴ λέοντος σκύμνον ἐν πόλει τρέφειν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1431b.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1431b.1.text#{μάλιστα μὲν λέοντα μὴ ν' πόλει τρέφειν,}
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1432.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1432.1.text#ἢν δ' ἐκτραφῇ τις, τοῖς τρόποις ὑπηρετεῖν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1433.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1433.1.text#νὴ τὸν Δία τὸν σωτῆρα δυσκρίτως γ' ἔχω·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1434.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1434.1.text#ὁ μὲν σοφῶς γὰρ εἶπεν, ὁ δ' ἕτερος σαφῶς.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1435.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1435.1.text#ἀλλ' ἔτι μίαν γνώμην ἑκάτερος εἴπατον 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1436.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1436.1.text#περὶ τῆς πόλεως ἥντιν' ἔχετον σωτηρίαν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1437.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1437.1.text#εἴ τις πτερώσας Κλεόκριτον Κινησίᾳ, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1438.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1438.1.text#αἴροιεν αὖραι πελαγίαν ὑπὲρ πλάκα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1439.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1439.1.text#γέλοιον ἂν φαίνοιτο· νοῦν δ' ἔχει τίνα; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1440.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1440.1.text#εἰ ναυμαχοῖεν κᾆτ' ἔχοντες ὀξίδας 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1441.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1441.1.text#ῥαίνοιεν ἐς τὰ βλέφαρα τῶν ἐναντίων. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1442.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1442.1.text#ἐγὼ μὲν οἶδα καὶ θέλω φράζειν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1442.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1442.2.text#λέγε.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1443.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1443.1.text#ὅταν τὰ νῦν ἄπιστα πίσθ' ἡγώμεθα,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1444.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1444.1.text#τὰ δ' ὄντα πίστ' ἄπιστα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1444.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1444.2.text#πῶς; οὐ μανθάνω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1445.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1445.1.text#ἀμαθέστερόν πως εἰπὲ καὶ σαφέστερον. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1446.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1446.1.text#εἰ τῶν πολιτῶν οἷσι νῦν πιστεύομεν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1447.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1447.1.text#τούτοις ἀπιστήσαιμεν, οἷς δ' οὐ χρώμεθα, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1448.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1448.1.text#τούτοισι χρησαίμεσθ', ἴσως σωθεῖμεν ἄν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1449.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1449.1.text#εἰ νῦν γε δυστυχοῦμεν ἐν τούτοισι, πῶς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1450.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1450.1.text#τἀναντί' ἂν πράττοντες οὐ σῳζοίμεθ' ἄν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1451.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1451.1.text#εὖ γ' ὦ Παλάμηδες, ὦ σοφωτάτη φύσις.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1452.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1452.1.text#ταυτὶ πότερ' αὐτὸς ηὗρες ἢ Κηφισοφῶν;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1453.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1453.1.text#ἐγὼ μόνος· τὰς δ' ὀξίδας Κηφισοφῶν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1454.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1454.1.text#τί δαὶ σύ; τί λέγεις;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1454.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1454.2.text#τὴν πόλιν νῦν μοι φράσον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1455.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1455.1.text#πρῶτον τίσι χρῆται· πότερα τοῖς χρηστοῖς;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1455.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1455.2.text#πόθεν; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1456.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1456.1.text#μισεῖ κάκιστα.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1456.2.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1456.2.text#τοῖς πονηροῖς δ' ἥδεται;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1457.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1457.1.text#οὐ δῆτ' ἐκείνη γ', ἀλλὰ χρῆται πρὸς βίαν. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1458.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1458.1.text#πῶς οὖν τις ἂν σώσειε τοιαύτην πόλιν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1459.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1459.1.text#ᾗ μήτε χλαῖνα μήτε σισύρα συμφέρει; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1460.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1460.1.text#εὕρισκε νὴ Δί', εἴπερ ἀναδύσει πάλιν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1461.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1461.1.text#ἐκεῖ φράσαιμ' ἄν· ἐνθαδὶ δ' οὐ βούλομαι. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1462.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1462.1.text#μὴ δῆτα σύ γ', ἀλλ' ἐνθένδ' ἀνίει τἀγαθά. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1463.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1463.1.text#τὴν γῆν ὅταν νομίσωσι τὴν τῶν πολεμίων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1464.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1464.1.text#εἶναι σφετέραν, τὴν δὲ σφετέραν τῶν πολεμίων,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1465.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1465.1.text#πόρον δὲ τὰς ναῦς ἀπορίαν δὲ τὸν πόρον.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1466.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1466.1.text#εὖ, πλήν γ' ὁ δικαστὴς αὐτὰ καταπίνει μόνος.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1467.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1467.1.text#κρίνοις ἄν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1467.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1467.2.text#αὕτη σφῷν κρίσις γενήσεται·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1468.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1468.1.text#αἱρήσομαι γὰρ ὅνπερ ἡ ψυχὴ θέλει. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1469.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1469.1.text#μεμνημένος νυν τῶν θεῶν οὓς ὤμοσας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1470.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1470.1.text#ἦ μὴν ἀπάξειν μ' οἴκαδ', αἱροῦ τοὺς φίλους.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1471.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1471.1.text# “ἡ γλῶττ' ὀμώμοκ',” Αἰσχύλον δ' αἱρήσομαι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1472.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1472.1.text#τί δέδρακας ὦ μιαρώτατ' ἀνθρώπων;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1472.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1472.2.text#ἐγώ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1473.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1473.1.text#ἔκρινα νικᾶν Αἰσχύλον. τιὴ γὰρ οὔ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1474.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1474.1.text#αἴσχιστον ἔργον προσβλέπεις μ' εἰργασμένος; 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1475.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1475.1.text#τί δ' αἰσχρόν, ἢν μὴ τοῖς θεωμένοις δοκῇ;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1476.1.speaker#Εὐριπίδης
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1476.1.text#ὦ σχέτλιε περιόψει με δὴ τεθνηκότα;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1477.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1477.1.text#τίς οἶδεν εἰ τὸ ζῆν μέν ἐστι κατθανεῖν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1478.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1478.1.text#τὸ πνεῖν δὲ δειπνεῖν, τὸ δὲ καθεύδειν κῴδιον;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1479.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1479.1.text#χωρεῖτε τοίνυν ὦ Διόνυσ' εἴσω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1479.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1479.2.text#τί δαί;
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1480.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1480.1.text#ἵνα ξενίσω 'γ'ὼ σφὼ πρὶν ἀποπλεῖν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1480.2.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1480.2.text#εὖ λέγεις
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1481.1.speaker#Διόνυσος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1481.1.text#νὴ τὸν Δί'· οὐ γὰρ ἄχθομαι τῷ πράγματι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1482.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1482.1.text#μακάριός γ' ἀνὴρ ἔχων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1483.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1483.1.text#ξύνεσιν ἠκριβωμένην.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1484.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1484.1.text#πάρα δὲ πολλοῖσιν μαθεῖν.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1485.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1485.1.text#ὅδε γὰρ εὖ φρονεῖν δοκήσας 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1486.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1486.1.text#πάλιν ἄπεισιν οἴκαδ' αὖ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1487.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1487.1.text#ἐπ' ἀγαθῶ μὲν τοῖς πολίταις,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1488.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1488.1.text#ἐπ' ἀγαθῷ δὲ τοῖς ἑαυτοῦ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1489.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1489.1.text#ξυγγενέσι τε καὶ φίλοισι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1490.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1490.1.text#διὰ τὸ συνετὸς εἶναι.  
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1491.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1491.1.text#χαρίεν οὖν μὴ Σωκράτει
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1492.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1492.1.text#παρακαθήμενον λαλεῖν,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1493.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1493.1.text#ἀποβαλόντα μουσικὴν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1494.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1494.1.text#τά τε μέγιστα παραλιπόντα
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1495.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1495.1.text#τῆς τραγῳδικῆς τέχνης.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1496.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1496.1.text#τὸ δ' ἐπὶ σεμνοῖσιν λόγοισι
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1497.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1497.1.text#καὶ σκαριφησμοῖσι λήρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1498.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1498.1.text#διατριβὴν ἀργὸν ποιεῖσθαι,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1499.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1499.1.text#παραφρονοῦντος ἀνδρός. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1500.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1500.1.text#ἄγε δὴ χαίρων Αἰσχύλε χώρει, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1501.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1501.1.text#καὶ σῷζε πόλιν τὴν ἡμετέραν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1502.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1502.1.text#γνώμαις ἀγαθαῖς καὶ παίδευσον
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1503.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1503.1.text#τοὺς ἀνοήτους· πολλοὶ δ' εἰσίν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1504.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1504.1.text#καὶ δὸς τουτὶ Κλεοφῶντι φέρων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1505.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1505.1.text#καὶ τουτὶ τοῖσι πορισταῖς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1506.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1506.1.text#Μύρμηκί θ' ὁμοῦ καὶ Νικομάχῳ,
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1507.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1507.1.text#τόδε δ' Ἀρχενόμῳ·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1508.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1508.1.text#καὶ φράζ' αὐτοῖς ταχέως ἥκειν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1509.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1509.1.text#ὡς ἐμὲ δευρὶ καὶ μὴ μέλλειν·
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1510.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1510.1.text#κἂν μὴ ταχέως ἥκωσιν, ἐγὼ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1511.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1511.1.text#νὴ τὸν Ἀπόλλω στίξας αὐτοὺς
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1512.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1512.1.text#καὶ συμποδίσας
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1513.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1513.1.text#μετ' Ἀδειμάντου τοῦ Λευκολόφου
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1514.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1514.1.text#κατὰ γῆς ταχέως ἀποπέμψω.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1515.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1515.1.text#ταῦτα ποιήσω· σὺ δὲ τὸν θᾶκον 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1516.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1516.1.text#τὸν ἐμὸν παράδος Σοφοκλεῖ τηρεῖν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1517.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1517.1.text#καὶ διασῴζειν, ἢν ἄρ' ἐγώ ποτε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1518.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1518.1.text#δεῦρ' ἀφίκωμαι. τοῦτον γὰρ ἐγὼ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1519.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1519.1.text#σοφίᾳ κρίνω δεύτερον εἶναι.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1520.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1520.1.text#μέμνησο δ' ὅπως ὁ πανοῦργος ἀνὴρ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1521.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1521.1.text#καὶ ψευδολόγος καὶ βωμολόχος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1522.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1522.1.text#μηδέποτ' ἐς τὸν θᾶκον τὸν ἐμὸν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1523.1.speaker#Αἰσχύλος
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1523.1.text#μηδ' ἄκων ἐγκαθεδεῖται.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1524.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1524.1.text#φαίνετε τοίνυν ὑμεῖς τούτῳ
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1525.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1525.1.text#λαμπάδας ἱεράς, χἄμα προπέμπετε
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1526.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1526.1.text#τοῖσιν τούτου τοῦτον μέλεσιν
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1527.1.speaker#Πλούτων
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1527.1.text#καὶ μολπαῖσιν κελαδοῦντες. 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1528.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1528.1.text#πρῶτα μὲν εὐοδίαν ἀγαθὴν ἀπιόντι ποιητῇ 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1529.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1529.1.text#ἐς φάος ὀρνυμένῳ δότε δαίμονες οἱ κατὰ γαίας, 
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1530.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1530.1.text#τῇ δὲ πόλει μεγάλων ἀγαθῶν ἀγαθὰς ἐπινοίας.
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1531.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1531.1.text#πάγχυ γὰρ ἐκ μεγάλων ἀχέων παυσαίμεθ' ἂν οὕτως
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1532.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1532.1.text#ἀργαλέων τ' ἐν ὅπλοις ξυνόδων. Κλεοφῶν δὲ μαχέσθω
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1533.1.speaker#Χορός
urn:cts:greekLit:tlg0019.tlg009.fu.sp:1533.1.text#κἄλλος ὁ βουλόμενος τούτων πατρίοις ἐν ἀρούραις. 
